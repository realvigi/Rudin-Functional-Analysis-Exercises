\begin{align*}
f\left(s\right) & =\intop_{0}^{s}f^{\prime}\left(t\right)dt=\intop_{0}^{s}\lambda^{-1}\left(Tf\right)^{\prime}\left(t\right)dt\\
 & =\lambda^{-1}\intop_{0}^{s}\left(F\left(1\right)-G\left(1\right)-F\left(t\right)\right)dt
\end{align*}

\end_inset

אבל 
\begin_inset Formula $F$
\end_inset

 רציפה, ולכן האינטגרנד של האינטגרל האחרון רציף, ולכן 
\begin_inset Formula $f$
\end_inset

 גזירה בכל מקום ומתקיים 
\begin_inset Formula $\lambda f^{\prime}=F\left(1\right)-G\left(1\right)-F$
\end_inset

 בכל 
\begin_inset Formula $I$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז גם 
\begin_inset Formula $f^{\prime}$
\end_inset

 היא רציפה בהחלט, ובאופן דומה לכל 
\begin_inset Formula $s$
\end_inset

 נקבל
\begin_inset Formula 
\begin{align*}
f^{\prime}\left(s\right) & =\intop_{0}^{s}f^{\prime\prime}\left(t\right)dt=-\lambda^{-1}\intop_{0}^{s}F^{\prime}\left(t\right)dt\\
 & =-\lambda^{-1}\intop_{0}^{s}f\left(t\right)dt
\end{align*}

\end_inset

אבל כבר ראינו ש-
\begin_inset Formula $f$
\end_inset

 רציפה! ולכן שוב מהמשפט היסודי נקבל ש-
\begin_inset Formula $f^{\prime\prime}$
\end_inset

 גזירה בכל מקום ומתקיים 
\begin_inset Formula $\lambda f^{\prime\prime}=-f$
\end_inset

.
\begin_inset Newline newline
\end_inset

זה כבר מראה באינדוקציה ש-
\begin_inset Formula $f$
\end_inset

 גזירה אינסוף פעמים בכל מקום ומתקיים 
\begin_inset Formula $\lambda f^{\prime\prime}+f=0$
\end_inset

.
\begin_inset Newline newline
\end_inset

כלומר 
\begin_inset Formula $f$
\end_inset

 היא פתרון למשוואה הדיפרנציאלית הלינארית 
\begin_inset Formula $x^{\prime\prime}=-\lambda^{-1}x$
\end_inset

.
\begin_inset Newline newline
\end_inset

מרחב הפתרונות המרוכבים של המשוואה הזאת הוא מממד 
\begin_inset Formula $2$
\end_inset

.
\begin_inset Newline newline
\end_inset

יהא 
\begin_inset Formula $\alpha\in\kaliComplex$
\end_inset

 כלשהו עבורו 
\begin_inset Formula $\alpha^{2}=\lambda$
\end_inset

, ונגדיר
\begin_inset Formula 
\begin{align*}
g\left(t\right) & =\sin\left(\alpha^{-1}t\right)\\
h\left(t\right) & =\cos\left(\alpha^{-1}t\right)
\end{align*}

\end_inset

אז 
\begin_inset Formula $g,h$
\end_inset

 חלקות ומתקיים
\begin_inset Formula 
\begin{align*}
g^{\prime\prime}\left(t\right) & =-\alpha^{-2}\sin\left(\alpha^{-1}t\right)=-\lambda^{-1}g\left(t\right)\\
h^{\prime\prime}\left(t\right) & =-\alpha^{-2}\cos\left(\alpha^{-1}t\right)=-\lambda^{-1}h\left(t\right)
\end{align*}

\end_inset

כלומר 
\begin_inset Formula $g,h$
\end_inset

 הם פתרונות למשוואה האחרונה, והן בת
\begin_inset Quotes erd
\end_inset

ל מעל 
\begin_inset Formula $\kaliComplex$
\end_inset

, ולכן הן מהוות בסיס למרחב הפתרונות.
 אז יש 
\begin_inset Formula $\beta_{1},\beta_{2}\in\kaliComplex$
\end_inset

 עבורם 
\begin_inset Formula $f=\beta_{1}g+\beta_{2}h$
\end_inset

.
\begin_inset Newline newline
\end_inset

מתקיים
\begin_inset Formula 
\begin{align*}
\lambda f\left(0\right) & =Tf\left(0\right)=G\left(0\right)+0\cdot F\left(1\right)-0\cdot F\left(0\right)-0\cdot G\left(1\right)=0\\
\lambda f\left(1\right) & =Tf\left(1\right)=G\left(1\right)+1\cdot F\left(1\right)-1\cdot F\left(1\right)-1\cdot G\left(1\right)=0
\end{align*}

\end_inset

ולכן 
\begin_inset Formula 
\begin{align*}
\beta_{2} & =\beta_{1}\sin\left(0\right)+\beta_{2}\cos\left(0\right)=\beta_{1}g\left(0\right)+\beta_{2}h\left(0\right)=0
\end{align*}

\end_inset

ולכן 
\begin_inset Formula $f=\beta_{1}g$
\end_inset

.
 משרירותיות 
\begin_inset Formula $f$
\end_inset

, זה מראה שהמרחב העצמי שמתאים ל-
\begin_inset Formula $\lambda$
\end_inset

 הוא חד ממדי, כנדרש.
\begin_inset Newline newline
\end_inset

כמו כן נקבל
\begin_inset Formula 
\[
\beta_{1}\sin\left(\alpha^{-1}\right)=\beta_{1}g\left(1\right)=f\left(1\right)=0
\]

\end_inset

מכך ש-
\begin_inset Formula $f\neq0$
\end_inset

, מתקיים 
\begin_inset Formula $\beta_{1}\neq0$
\end_inset

, ולכן קיבלנו 
\begin_inset Formula $\sin\left(\alpha^{-1}\right)=0$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז יש 
\begin_inset Formula $k$
\end_inset

 שלם עבורו 
\begin_inset Formula $\alpha^{-1}=k\pi$
\end_inset

, ולכן 
\begin_inset Formula $\lambda=\left(k\pi\right)^{-2}$
\end_inset

, ואם נבחר את 
\begin_inset Formula $n$
\end_inset

 להיות השורש החיובי של 
\begin_inset Formula $k^{2}$
\end_inset

, אז 
\begin_inset Formula $\lambda=\left(n\pi\right)^{-2}$
\end_inset

.
\begin_inset Newline newline
\end_inset

משרירותיות 
\begin_inset Formula $f$
\end_inset

, זה מראה שאם 
\begin_inset Formula $\lambda$
\end_inset

 ערך עצמי של 
\begin_inset Formula $T$
\end_inset

, אז 
\begin_inset Formula $\lambda=\left(n\pi\right)^{-2}$
\end_inset

 עבור 
\begin_inset Formula $n$
\end_inset

 שלם חיובי כלשהו.
\begin_inset Newline newline
\end_inset

מצד שני, אם 
\begin_inset Formula $\lambda=\left(n\pi\right)^{-2}$
\end_inset

 עבור 
\begin_inset Formula $n$
\end_inset

 שלם חיובי, וניקח 
\begin_inset Formula $f\left(t\right)=\sin n\pi t$
\end_inset

, אז חישוב ישיר מראה 
\begin_inset Formula $Tf=\lambda f$
\end_inset

, ולכן 
\begin_inset Formula $\lambda$
\end_inset

 ע
\begin_inset Quotes erd
\end_inset

ע של 
\begin_inset Formula $T$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז הע
\begin_inset Quotes erd
\end_inset

ע של 
\begin_inset Formula $T$
\end_inset

 הם בדיוק 
\begin_inset Formula $\left(n\pi\right)^{-2}$
\end_inset

 עבור 
\begin_inset Formula $n=1,2,\ldots$
\end_inset

, ויש להם פונקציות עצמיות 
\begin_inset Formula $t\mapsto\sin n\pi t$
\end_inset

 עבור 
\begin_inset Formula $n=1,2,\ldots$
\end_inset

 בהתאמה.
\end_layout

\begin_layout Enumerate
לכל 
\begin_inset Formula $n$
\end_inset

 נסמן 
\begin_inset Formula $u_{n}\left(t\right)=\sin n\pi t$
\end_inset

.
 לכל 
\begin_inset Formula $n,m$
\end_inset

 מתקיים
\begin_inset Formula 
\begin{align*}
u_{n}\left(t\right)u_{m}\left(t\right) & =\sin\left(n\pi t\right)\sin\left(m\pi t\right)=\frac{e^{in\pi t}-e^{-in\pi t}}{2i}\cdot\frac{e^{im\pi t}-e^{-im\pi t}}{2i}\\
 & =\frac{1}{4}\left(e^{i\left(n-m\right)\pi t}+e^{-i\left(n-m\right)\pi t}-\left(e^{i\left(n+m\right)\pi t}+e^{-i\left(n+m\right)\pi t}\right)\right)\\
 & =\frac{1}{4}\left(2\cos\left(\left(n-m\right)\pi t\right)-2\cos\left(\left(n+m\right)\pi t\right)\right)\\
 & =\frac{1}{2}\left(\cos\left(\left(n-m\right)\pi t\right)-\cos\left(\left(n+m\right)\pi t\right)\right)
\end{align*}

\end_inset

ולכן עבור 
\begin_inset Formula $n\neq m$
\end_inset

 נקבל
\begin_inset Formula 
\begin{align*}
\left\langle u_{n},u_{m}\right\rangle  & =\frac{1}{2}\intop_{0}^{1}\cos\left(\left(n-m\right)\pi t\right)-\cos\left(\left(n+m\right)\pi t\right)dt\\
 & =\frac{1}{2}\left[\left(\frac{\sin\left(\left(n-m\right)\pi\right)}{\left(n-m\right)\pi}-\frac{\sin\left(\left(n+m\right)\pi\right)}{\left(n+m\right)\pi}\right)-\left(\frac{\sin\left(0\right)}{\left(n-m\right)\pi}-\frac{\sin\left(0\right)}{\left(n+m\right)\pi}\right)\right]\\
 & =0
\end{align*}

\end_inset

ולכן 
\begin_inset Formula $\left\{ u_{n}\right\} $
\end_inset

 סדרה אורתונגונלית.
\begin_inset Newline newline
\end_inset

תהא 
\begin_inset Formula $f\in L^{2}\left(I\right)$
\end_inset

 עבורה 
\begin_inset Formula $\left\langle f,u_{n}\right\rangle =0$
\end_inset

 לכל 
\begin_inset Formula $n$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז לכל 
\begin_inset Formula $n$
\end_inset

 מתקיים 
\begin_inset Formula $\intop_{0}^{1}\sin\left(2\pi nt\right)f\left(t\right)dt$
\end_inset

.
\begin_inset Newline newline
\end_inset

לכל 
\begin_inset Formula $t\in\left[0,\pi\right]$
\end_inset

 נגדיר 
\begin_inset Formula $F\left(t\right)=f\left(\pi^{-1}t\right)$
\end_inset

, ולכל 
\begin_inset Formula $t\in\left[-\pi,0\right]$
\end_inset

 נגדיר 
\begin_inset Formula $F\left(t\right)=-f\left(-\pi^{-1}t\right)$
\end_inset

.
 אז 
\begin_inset Formula $F\in L^{2}\left(\left[-\pi,\pi\right]\right)$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז לכל 
\begin_inset Formula $n$
\end_inset

 שלם חיובי מתקיים
\begin_inset Formula 
\begin{align*}
\intop_{-\pi}^{\pi}e^{int}F\left(t\right)dt & =-\intop_{-\pi}^{0}e^{int}f\left(-\pi^{-1}t\right)dt+\intop_{0}^{\pi}e^{int}f\left(\pi^{-1}t\right)dt\\
 & =-\pi\intop_{0}^{1}e^{-i\pi ns}f\left(s\right)ds+\pi\intop_{0}^{1}e^{i\pi ns}f\left(s\right)ds\\
 & =\pi\intop_{0}^{1}\left(e^{i\pi ns}-e^{-i\pi ns}\right)f\left(s\right)ds\\
 & =2\pi i\intop_{0}^{1}\sin\pi nsf\left(s\right)ds=2\pi i\left\langle f,u_{n}\right\rangle =0
\end{align*}

\end_inset

כמו כן 
\begin_inset Formula $F$
\end_inset

 היא אי-זוגית, ולכן עבור 
\begin_inset Formula $n$
\end_inset

 שלם שלילי מתקיים
\begin_inset Formula 
\[
\intop_{-\pi}^{\pi}e^{int}F\left(t\right)dt=-\intop_{-\pi}^{\pi}e^{int}F\left(-t\right)dt=-\intop_{-\pi}^{\pi}e^{-int}F\left(t\right)dt=0
\]

\end_inset

ולבסוף מתקיים גם 
\begin_inset Formula $\intop_{-\pi}^{\pi}F\left(t\right)dt=0$
\end_inset

, שוב מכך ש-
\begin_inset Formula $F$
\end_inset

 אי-זוגית.
\begin_inset Newline newline
\end_inset

זה מראה שכל מקדמי פוריה של 
\begin_inset Formula $F$
\end_inset

 הם אפסים, ולכן 
\begin_inset Formula $F=0$
\end_inset

, ולכן כמעט לכל 
\begin_inset Formula $t\in\left[0,\pi\right]$
\end_inset

 נקבל 
\begin_inset Formula $f\left(\pi^{-1}t\right)=0$
\end_inset

, ולכן כמעט לכל 
\begin_inset Formula $s\in\left[0,1\right]$
\end_inset

 נקבל 
\begin_inset Formula $f\left(s\right)=0$
\end_inset

 כלומר 
\begin_inset Formula $f=0$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז 
\begin_inset Formula $\left\{ u_{n}\right\} $
\end_inset

 היא קבוצה אורתוגונלית מקסימלית ב-
\begin_inset Formula $L^{2}\left(I\right)$
\end_inset

 ולכן מהווה בסיס אורתוגונלי כנדרש.
\end_layout

\begin_layout Enumerate
כל הטורים של הפונקציות יובנו בסעיף הזה יובנו כגבולות ב-
\begin_inset Formula $L^{2}\left(I\right)$
\end_inset

.
\begin_inset Newline newline
\end_inset

נניח 
\begin_inset Formula $Tf-\lambda f=g$
\end_inset

 עבור 
\begin_inset Formula $f\in L^{2}\left(I\right)$
\end_inset

 כלשהי.
\begin_inset Newline newline
\end_inset

אז מרציפות 
\begin_inset Formula $T$
\end_inset

 מתקיים 
\begin_inset Formula 
\[
\sum_{n=1}^{\infty}\left\langle f,u_{n}\right\rangle Tu_{n}-\lambda u_{n}=T\sum_{n=1}^{\infty}\left\langle f,u_{n}\right\rangle u_{n}-\lambda\sum_{n=1}^{\infty}\left\langle f,u_{n}\right\rangle u_{n}=\sum_{n=1}^{\infty}c_{n}u_{n}
\]

\end_inset

אבל כפי שראינו בסעיף הראשון, 
\begin_inset Formula $Tu_{n}=\left(n\pi\right)^{-2}u_{n}$
\end_inset

 ולכן
\begin_inset Formula 
\[
\sum_{n=1}^{\infty}\left\langle f,u_{n}\right\rangle \left(\frac{1}{n^{2}\pi^{2}}-\lambda\right)u_{n}=\sum_{n=1}^{\infty}c_{n}u_{n}
\]

\end_inset

כלומר
\begin_inset Formula 
\[
\sum_{n=1}^{\infty}\left(\left\langle f,u_{n}\right\rangle \left(\frac{1}{n^{2}\pi^{2}}-\lambda\right)-c_{n}\right)u_{n}=0
\]

\end_inset

ולכן לכל 
\begin_inset Formula $m$
\end_inset

 מתקיים
\begin_inset Formula 
\[
\left\langle f,u_{m}\right\rangle \left(\frac{1}{m^{2}\pi^{2}}-\lambda\right)-c_{m}=\sum_{n=1}^{\infty}\left(\left\langle f,u_{n}\right\rangle \left(\frac{1}{n^{2}\pi^{2}}-\lambda\right)-c_{n}\right)\left\langle u_{n},u_{m}\right\rangle =\left\langle \sum_{n=1}^{\infty}\left(\left\langle f,u_{n}\right\rangle \left(\frac{1}{n^{2}\pi^{2}}-\lambda\right)-c_{n}\right)u_{n},u_{m}\right\rangle =0
\]

\end_inset

ולכן לכל 
\begin_inset Formula $n$
\end_inset

 מתקיים 
\begin_inset Formula $c_{n}=\left\langle f,u_{n}\right\rangle \left(\left(n\pi\right)^{-2}-\lambda\right)$
\end_inset

.
\begin_inset Newline newline
\end_inset

מצד שני, אם 
\begin_inset Formula $f\in L^{2}\left(I\right)$
\end_inset

 ולכל 
\begin_inset Formula $n$
\end_inset

 מתקיים 
\begin_inset Formula $c_{n}=\left\langle f,u_{n}\right\rangle \left(\left(n\pi\right)^{-2}-\lambda\right)$
\end_inset

, אז
\begin_inset Formula 
\[
Tf-\lambda f=\sum_{n=1}^{\infty}\left\langle f,u_{n}\right\rangle \left(Tu_{n}-\lambda u_{n}\right)=\sum_{n=1}^{\infty}\left\langle f,u_{n}\right\rangle \left(\frac{1}{n^{2}\pi^{2}}-\lambda\right)u_{n}=\sum_{n=1}^{\infty}c_{n}u_{n}=g
\]

\end_inset

כלומר 
\begin_inset Formula $f$
\end_inset

 היא פתרון של המשוואה 
\begin_inset Formula $Tf-\lambda f=g$
\end_inset

 אם
\begin_inset Quotes erd
\end_inset

ם 
\begin_inset Formula $c_{n}=\left\langle f,u_{n}\right\rangle \left(\left(n\pi\right)^{-2}-\lambda\right)$
\end_inset

 לכל 
\begin_inset Formula $n$
\end_inset

.
\begin_inset Newline newline
\end_inset

אם 
\begin_inset Formula $\lambda$
\end_inset

 הוא לא ערך עצמי של 
\begin_inset Formula $T$
\end_inset

, אז לכל 
\begin_inset Formula $n$
\end_inset

 מתקיים 
\begin_inset Formula $\left(n\pi\right)^{-2}-\lambda\neq0$
\end_inset

, ולכן במקרה הזה 
\begin_inset Formula $f$
\end_inset

 היא פתרון אם
\begin_inset Quotes erd
\end_inset

ם לכל 
\begin_inset Formula $n$
\end_inset

 מתקיים 
\begin_inset Formula 
\[
\left\langle f,u_{n}\right\rangle =\left(\frac{1}{n^{2}\pi^{2}}-\lambda\right)^{-1}c_{n}=\frac{n^{2}\pi^{2}}{1-\lambda n^{2}\pi^{2}}c_{n}
\]

\end_inset

וזה קורה אם
\begin_inset Quotes erd
\end_inset

ם 
\begin_inset Formula 
\[
f=\sum_{n=1}^{\infty}\frac{n^{2}\pi^{2}}{1-\lambda n^{2}\pi^{2}}c_{n}u_{n}
\]

\end_inset

ולכן הטור הזה הוא הפתרון היחיד למשוואה במקרה בו 
\begin_inset Formula $\lambda$
\end_inset

 אינו ע
\begin_inset Quotes erd
\end_inset

ע של 
\begin_inset Formula $T$
\end_inset

.
\begin_inset Newline newline
\end_inset

אם 
\begin_inset Formula $\lambda$
\end_inset

 הוא כן ע
\begin_inset Quotes erd
\end_inset

ע, אז יש 
\begin_inset Formula $m$
\end_inset

 עבורו 
\begin_inset Formula $\lambda=\left(m\pi\right)^{-2}$
\end_inset

, ואז 
\begin_inset Formula $\left(n\pi\right)^{-2}-\lambda\neq0$
\end_inset

 לכל 
\begin_inset Formula $n\neq m$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז במקרה הזה 
\begin_inset Formula $f$
\end_inset

 פתרון אם
\begin_inset Quotes erd
\end_inset

ם 
\begin_inset Formula $c_{m}=0$
\end_inset

 וגם לכל 
\begin_inset Formula $n\neq m$
\end_inset

 מתקיים
\begin_inset Formula 
\[
\left\langle f,u_{n}\right\rangle =\frac{n^{2}\pi^{2}}{1-\lambda n^{2}\pi^{2}}c_{n}
\]

\end_inset

כלומר אם 
\begin_inset Formula $c_{m}\neq0$
\end_inset

, אז אין למשוואה פתרונות בכלל, ואחרת 
\begin_inset Formula $f$
\end_inset

 פתרון למשוואה אם
\begin_inset Quotes erd
\end_inset

ם קיים 
\begin_inset Formula $\alpha\in\kaliComplex$
\end_inset

 עבורו
\begin_inset Formula 
\[
f=\alpha u_{m}+\sum_{n\neq m}\frac{n^{2}\pi^{2}}{1-\lambda n^{2}\pi^{2}}c_{n}u_{n}
\]

\end_inset


\end_layout

\begin_layout Enumerate
תהא 
\begin_inset Formula $\left\{ f_{i}\right\} $
\end_inset

 סדרה חסומה ב-
\begin_inset Formula $C$
\end_inset

.
 כלומר יש 
\begin_inset Formula $M>0$
\end_inset

 עבורו 
\begin_inset Formula $\left\Vert f_{i}\right\Vert _{\infty}<M$
\end_inset

 לכל 
\begin_inset Formula $i$
\end_inset

.
\begin_inset Newline newline
\end_inset

יהא 
\begin_inset Formula $\varepsilon>0$
\end_inset

.
 
\begin_inset Formula $K$
\end_inset

 רציפה על הקבוצה הקומפקטית 
\begin_inset Formula $\left[0,1\right]^{2}$
\end_inset

 ביחס למטריקה שמושרת מנורמת 
\begin_inset Formula $\ell^{\infty}$
\end_inset

 על 
\begin_inset Formula $R^{2}$
\end_inset

, ולכן רציפה במידה שווה יחס לאותה מטריקה, ובפרט יש 
\begin_inset Formula $\delta>0$
\end_inset

 כך שלכל 
\begin_inset Formula $s_{1},s_{2},t_{1},t_{2}\in I$
\end_inset

, אם 
\begin_inset Formula $\left|s_{1}-s_{2}\right|,\left|t_{1}-t_{2}\right|<\delta$
\end_inset

, אז 
\begin_inset Formula $\left|K\left(s_{1},t_{1}\right)-K\left(s_{2},t_{2}\right)\right|<M^{-1}\varepsilon$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז בפרט לכל 
\begin_inset Formula $s_{1},s_{2}\in I$
\end_inset

, אם 
\begin_inset Formula $\left|s_{1}-s_{2}\right|<\delta$
\end_inset

, אז לכל 
\begin_inset Formula $i$
\end_inset

 נקבל 
\begin_inset Formula 
\begin{align*}
\left|Tf_{i}\left(s_{1}\right)-Tf_{i}\left(s_{2}\right)\right| & =\left|\intop_{0}^{1}K\left(s_{1},t\right)-K\left(s_{2},t\right)f_{i}\left(t\right)dt\right|\\
 & \leq\intop_{0}^{1}\left|K\left(s_{1},t\right)-K\left(s_{2},t\right)\right|\left|f_{i}\left(t\right)\right|dt\\
 & \leq\left\Vert f_{i}\right\Vert _{\infty}\intop_{0}^{1}\left|K\left(s_{1},t\right)-K\left(s_{2},t\right)\right|dt\\
 & <M\intop_{0}^{1}M^{-1}\varepsilon dt=\varepsilon
\end{align*}

\end_inset

וזה מראה שהסדרה 
