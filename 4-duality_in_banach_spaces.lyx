\[
Tf_{n}\left(s\right)=\frac{1}{s}\intop_{0}^{s}n^{-1}\chi_{\left[0,n^{2}\right]}\left(t\right)dt=\frac{1}{ns}\intop_{0}^{s}\chi_{\left[0,n^{2}\right]}\left(t\right)dt=\begin{cases}
n^{-1} & s\leq n^{2}\\
s^{-1}n & s>n^{2}
\end{cases}
