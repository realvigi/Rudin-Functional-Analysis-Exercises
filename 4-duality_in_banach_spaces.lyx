\begin_layout Enumerate
נקבע 
\begin_inset Formula $x\in\ell^{2}$
\end_inset

.
 נטען שלכל 
\begin_inset Formula $k\geq1$
\end_inset

 ולכל 
\begin_inset Formula $n$
\end_inset

 מתקיים
\begin_inset Formula 
\[
T^{k}x\left(n\right)=\begin{cases}
0 & n<k\\
\frac{\left(n-k+1\right)!}{\left(n+1\right)!}x\left(n-k\right) & n\geq k
\end{cases}
\]

\end_inset

עבור 
\begin_inset Formula $k=1$
\end_inset

, זו מתקבל בדיוק מההגדרה של 
\begin_inset Formula $T$
\end_inset

.
\begin_inset Newline newline
\end_inset

נניח שהשוויון הזה נכון עבור 
\begin_inset Formula $k\geq1$
\end_inset

 כלשהו.
\begin_inset Newline newline
\end_inset

אז לכל 
\begin_inset Formula $n\geq1$
\end_inset

 מתקיים
\begin_inset Newline newline
\end_inset


\begin_inset Formula 
\[
ST^{k}x\left(n\right)=T^{k}x\left(n-1\right)=\begin{cases}
0 & n-1<k\\
\frac{\left(n-k\right)!}{n!}x\left(n-k-1\right) & n-1\geq k
\end{cases}
\]

\end_inset

וכמו כן מהגדרת 
\begin_inset Formula $S$
\end_inset

, 
\begin_inset Formula $ST^{k}x\left(0\right)=0$
\end_inset

.
\begin_inset Newline newline
\end_inset

לכן לכל 
\begin_inset Formula $n$
\end_inset

 מתקיים
\begin_inset Formula 
\[
ST^{k}x\left(n\right)=\begin{cases}
0 & n<k+1\\
\frac{\left(n-k\right)!}{n!}x\left(n-\left(k+1\right)\right) & n\geq k+1
\end{cases}
\]

\end_inset

ולכן לכל 
\begin_inset Formula $n<k+1$
\end_inset

 מתקיים
\begin_inset Formula 
\[
T^{k+1}x\left(n\right)=MST^{k}x\left(n\right)=\frac{1}{n+1}ST^{k}x\left(n\right)=0
\]

\end_inset

ולכל 
\begin_inset Formula $n\geq k+1$
\end_inset

 מתקיים
\begin_inset Formula 
\begin{align*}
T^{k+1}x\left(n\right) & =MST^{k}x\left(n\right)=\frac{1}{n+1}ST^{k}x\left(n\right)\\
 & =\frac{1}{n+1}\cdot\frac{\left(n-k\right)!}{n!}x\left(n-\left(k+1\right)\right)\\
 & =\frac{\left(n-\left(k+1\right)+1\right)!}{\left(n+1\right)!}x\left(n-\left(k+1\right)\right)
\end{align*}

\end_inset

ולכן מאינדוקציה נקבל שזו הנוסחה עבור 
\begin_inset Formula $T^{k}x$
\end_inset

 לכל 
\begin_inset Formula $x\in\ell^{2}$
\end_inset

.
\begin_inset Newline newline
\end_inset

בפרט, לכל 
\begin_inset Formula $k\geq1$
\end_inset

 ולכל 
\begin_inset Formula $m,n$
\end_inset

 מתקיים
\begin_inset Formula 
\[
T^{k}e_{m}\left(n\right)=\begin{cases}
0 & n<k\\
\frac{\left(n-k+1\right)!}{\left(n+1\right)!}e_{m}\left(n-k\right) & n\geq k
\end{cases}
\]

\end_inset

אם נציב בנוסחה הזאת 
\begin_inset Formula $n\neq m+k$
\end_inset

, נקבל 
\begin_inset Formula $0$
\end_inset

, ואם נקבל בה 
\begin_inset Formula $n=m+k$
\end_inset

 נקבל 
\begin_inset Formula $\left(m+1\right)!\left(\left(m+k+1\right)!\right)^{-1}$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז לכל 
\begin_inset Formula $k\geq1$
\end_inset

 ולכל 
\begin_inset Formula $m$
\end_inset

 מתקיים
\begin_inset Formula 
\[
T^{k}e_{m}=\frac{\left(m+1\right)!}{\left(m+k+1\right)!}e_{m+k}
\]

\end_inset

ולכן גם
\begin_inset Formula 
\[
\left\Vert T^{k}e_{m}\right\Vert =\frac{\left(m+1\right)!}{\left(m+k+1\right)!}
\]

\end_inset

יהא 
\begin_inset Formula $x\in\ell^{2}$
\end_inset

 כלשהו עם 
\begin_inset Formula $\left\Vert x\right\Vert \leq1$
\end_inset

.
 
\begin_inset Newline newline
\end_inset

אז מתקיים 
\begin_inset Formula $x=\sum_{m=0}^{\infty}x\left(m\right)e_{m}$
\end_inset

 ומרציפות ולינאריות 
\begin_inset Formula $T^{k}$
\end_inset

, נקבל
\begin_inset Formula 
\begin{align*}
T^{k}x & =\sum_{m=0}^{\infty}x\left(m\right)T^{k}e_{m}=\sum_{m=0}^{\infty}x\left(m\right)\frac{\left(m+1\right)!}{\left(m+k+1\right)!}e_{m+k}
\end{align*}

\end_inset

ומכך ש-
\begin_inset Formula $\left\{ e_{m}\right\} $
\end_inset

 היא סדרה אורתונורמלית שלמה ב-
\begin_inset Formula $\ell^{2}$
\end_inset

, נקבל
\begin_inset Formula 
\begin{align*}
\left\Vert T^{k}x\right\Vert ^{2} & =\sum_{m=0}^{\infty}\left|x\left(m\right)\right|^{2}\left(\frac{\left(m+1\right)!}{\left(m+k+1\right)!}\right)^{2}
\end{align*}

\end_inset

לכל 
\begin_inset Formula $m$
\end_inset

 מתקיים
\begin_inset Formula 
\begin{align*}
\frac{\left(m+1\right)!}{\left(m+k+1\right)!} & =\prod_{j=m+2}^{m+k+1}\frac{1}{j}\leq\prod_{j=m+2}^{m+k+1}\frac{1}{j-m}\\
 & =\prod_{j=2}^{k+1}\frac{1}{j}=\frac{1}{\left(k+1\right)!}
\end{align*}

\end_inset

ולכן מכך ש-
\begin_inset Formula $\left\Vert x\right\Vert \leq1$
\end_inset

 נקבל
\begin_inset Formula 
\[
\left\Vert T^{k}x\right\Vert ^{2}\leq\left(\frac{1}{\left(k+1\right)!}\right)^{2}\sum_{m=0}^{\infty}\left|x\left(m\right)\right|^{2}\leq\left(\frac{1}{\left(k+1\right)!}\right)^{2}
\]

\end_inset

כלומר לכל 
\begin_inset Formula $x$
\end_inset

 עם 
\begin_inset Formula $\left\Vert x\right\Vert \leq1$
\end_inset

 מתקיים
\begin_inset Formula 
\[
\left\Vert T^{k}x\right\Vert \leq\frac{1}{\left(k+1\right)!}
\]

\end_inset

ולכן
\begin_inset Formula 
\[
\left\Vert T^{k}\right\Vert \leq\frac{1}{\left(k+1\right)!}
\]

\end_inset

מצד שני מתקיים
\begin_inset Formula 
\[
\left\Vert T^{k}e_{0}\right\Vert =\left\Vert \frac{1}{\left(k+1\right)!}e_{k}\right\Vert =\frac{1}{\left(k+1\right)!}
\]

\end_inset

ולכן
\begin_inset Formula 
\[
\left\Vert T^{k}\right\Vert \geq\frac{1}{\left(k+1\right)!}
\]

\end_inset

כלומר סך הכול קיבלנו
\begin_inset Formula 
\[
\left\Vert T^{k}\right\Vert =\frac{1}{\left(k+1\right)!}
\]

\end_inset

וזה הדבר בראשון שהיה צריך לחשב.
\begin_inset Newline newline
\end_inset

עכשיו נחשב את הגבול של 
\begin_inset Formula $\left\Vert T^{k}\right\Vert ^{\nicefrac{1}{k}}$
\end_inset

.
\begin_inset Newline newline
\end_inset

נסמן 
\begin_inset Formula $\alpha_{k}=\log\left(\left\Vert T^{k}\right\Vert ^{\nicefrac{1}{k}}\right)$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז
\begin_inset Formula 
\begin{align*}
\alpha_{k} & =\log\left(\left(\frac{1}{\left(k+1\right)!}\right)^{\nicefrac{1}{k}}\right)=-\frac{1}{k}\sum_{j=1}^{k}\log\left(j+1\right)
\end{align*}

\end_inset

אבל
\begin_inset Formula 
\begin{align*}
\sum_{j=1}^{k}\log\left(j+1\right) & \geq\sum_{j=\left\lfloor \nicefrac{k}{2}\right\rfloor }^{k}\log\left(j+1\right)\geq\left(k-\left\lfloor \nicefrac{k}{2}\right\rfloor +1\right)\log\left(\left\lfloor \nicefrac{k}{2}\right\rfloor +1\right)\\
 & \geq\left(k-\frac{k}{2}+1\right)\log\left(\frac{k}{2}-1+1\right)\\
 & \geq\frac{k}{2}\log\left(\frac{k}{2}\right)
\end{align*}

\end_inset

ולכן 
\begin_inset Formula 
\[
\frac{1}{k}\sum_{j=1}^{k}\log\left(j+1\right)\geq\log\left(\frac{k}{2}\right)
\]

\end_inset

כלומר
\begin_inset Formula 
\[
\frac{1}{k}\sum_{j=1}^{k}\log\left(j+1\right)\xrightarrow[k\rightarrow\infty]{}\infty
\]

\end_inset

ולכן 
\begin_inset Formula $\alpha_{k}\xrightarrow[k\rightarrow\infty]{}-\infty$
\end_inset

, ולכן 
\begin_inset Formula $\exp\alpha_{k}\xrightarrow[k\rightarrow\infty]{}0$
\end_inset

, כלומר 
\begin_inset Formula $\left\Vert T^{k}\right\Vert ^{\nicefrac{1}{k}}\rightarrow0$
\end_inset

.
\end_layout

