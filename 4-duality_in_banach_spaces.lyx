.
\begin_inset Newline newline
\end_inset

מהחלפת משתנה פשוטה, לכל 
\begin_inset Formula $f\in L^{2}$
\end_inset

 ולכל 
\begin_inset Formula $s>0$
\end_inset

 נקבל 
\begin_inset Formula $Tf\left(s\right)=\intop_{0}^{1}f\left(st\right)dt$
\end_inset

.
\begin_inset Newline newline
\end_inset

לכל 
\begin_inset Formula $s\in\left(0,\infty\right)$
\end_inset

 נגדיר 
\begin_inset Formula $h\left(s\right)=\intop_{0}^{1}\left|f\left(st\right)\right|dt$
\end_inset

.
 אז 
\begin_inset Formula $h\geq0$
\end_inset

.
\begin_inset Newline newline
\end_inset

לכל 
\begin_inset Formula $n$
\end_inset

 נגדיר 
\begin_inset Formula $h_{n}=\chi_{\left[0,n\right]}\cdot\min\left(h,n\right)$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז לכל 
\begin_inset Formula $n$
\end_inset

 מתקיים 
\begin_inset Formula $\left\Vert h_{n}\right\Vert _{2}^{2}\leq\left\Vert n\chi_{\left[0,n\right]}\right\Vert _{2}^{2}=n^{3}$
\end_inset

 ובפרט 
\begin_inset Formula $h_{n}\in L^{2}$
\end_inset

 לכל 
\begin_inset Formula $n$
\end_inset

.
\begin_inset Newline newline
\end_inset

ממשפט ההצגה של פונקציונלים על מרחבי 
\begin_inset Formula $L^{p}$
\end_inset

, נקבל 
\begin_inset Formula 
\[
\left\Vert h_{n}\right\Vert _{2}=\sup_{\left\Vert g\right\Vert _{2}\leq1}\left|\intop_{0}^{\infty}g\left(s\right)h_{n}\left(s\right)ds\right|
\]

\end_inset

אבל לכל 
\begin_inset Formula $g\in L^{2}$
\end_inset

 מתקיים
\begin_inset Formula 
\begin{align*}
\left|\intop_{0}^{\infty}g\left(s\right)h_{n}\left(s\right)ds\right| & \leq\intop_{0}^{\infty}\left|g\left(s\right)\right|\chi_{\left[0,n\right]}\left(s\right)\min\left(h\left(s\right),n\right)ds\\
 & \leq\intop_{0}^{n}\left|g\left(s\right)\right|h\left(s\right)ds=\intop_{0}^{n}\left|g\left(s\right)\right|\intop_{0}^{1}\left|f\left(st\right)\right|dtds\\
 & =\intop_{0}^{1}\intop_{0}^{n}\left|g\left(s\right)\right|\left|f\left(st\right)\right|dsdt\\
 & \leq\intop_{0}^{1}\left(\intop_{0}^{n}\left|g\left(s\right)\right|^{2}ds\right)^{\nicefrac{1}{2}}\left(\intop_{0}^{n}\left|f\left(st\right)\right|^{2}ds\right)^{\nicefrac{1}{2}}dt\\
 & \leq\left\Vert g\right\Vert _{2}\intop_{0}^{1}\left(\intop_{0}^{n}\left|f\left(st\right)\right|^{2}ds\right)^{\nicefrac{1}{2}}dt
\end{align*}

\end_inset

ולכן לכל 
\begin_inset Formula $n$
\end_inset

 נקבל
\begin_inset Formula 
\[
\left\Vert h_{n}\right\Vert _{2}\leq\intop_{0}^{1}\left(\intop_{0}^{n}\left|f\left(st\right)\right|^{2}ds\right)^{\nicefrac{1}{2}}dt
\]

\end_inset

 ואם נסמן 
\begin_inset Formula $\psi_{n}\left(t\right)=\left(\intop_{0}^{n}\left|f\left(st\right)\right|^{2}ds\right)^{\nicefrac{1}{2}}$
\end_inset

, אז קיבלנו
\begin_inset Formula 
\[
\left(\intop_{0}^{\infty}h_{n}^{2}\left(s\right)ds\right)^{\nicefrac{1}{2}}\leq\intop_{0}^{1}\psi_{n}\left(t\right)dt
\]

\end_inset

כמו כן הסדרות 
\begin_inset Formula $\left\{ \psi_{n}\right\} ,\left\{ h_{n}\right\} $
\end_inset

 שתיהן עולות נקודתית, ומתקיים
\begin_inset Formula 
\begin{align*}
h_{n}\left(s\right) & \xrightarrow[n\rightarrow\infty]{}h\left(s\right)\\
\psi_{n}\left(t\right) & \xrightarrow[n\rightarrow\infty]{}\left(\intop_{0}^{\infty}\left|f\left(st\right)\right|^{2}ds\right)^{\nicefrac{1}{2}}
\end{align*}

\end_inset

אז ממשפט ההתכנסות המונוטונית נקבל
\begin_inset Formula 
\begin{align*}
\left(\intop_{0}^{\infty}h_{n}^{2}\left(s\right)ds\right)^{\nicefrac{1}{2}} & \xrightarrow[n\rightarrow\infty]{}\left(\intop_{0}^{\infty}h^{2}\left(s\right)ds\right)^{\nicefrac{1}{2}}\\
\intop_{0}^{1}\psi_{n}\left(t\right)dt & \xrightarrow[n\rightarrow\infty]{}\intop_{0}^{1}\left(\intop_{0}^{\infty}\left|f\left(st\right)\right|^{2}ds\right)^{\nicefrac{1}{2}}dt
\end{align*}

\end_inset

ולכן
\begin_inset Formula 
\[
\left(\intop_{0}^{\infty}h^{2}\left(s\right)ds\right)^{\nicefrac{1}{2}}\leq\intop_{0}^{1}\left(\intop_{0}^{\infty}\left|f\left(st\right)\right|^{2}ds\right)^{\nicefrac{1}{2}}dt
\]

\end_inset

ואם נכניס פנימה את ההגדרה של 
\begin_inset Formula $h$
\end_inset

 קיבלנו
\begin_inset Formula 
\[
\left(\intop_{0}^{\infty}\left(\intop_{0}^{1}\left|f\left(st\right)\right|dt\right)^{2}ds\right)^{\nicefrac{1}{2}}\leq\intop_{0}^{1}\left(\intop_{0}^{\infty}\left|f\left(st\right)\right|^{2}ds\right)^{\nicefrac{1}{2}}dt
\]

\end_inset

ולכן
\begin_inset Formula 
\begin{align*}
\left\Vert Tf\right\Vert _{2} & =\left(\intop_{0}^{\infty}\left|Tf\left(s\right)\right|^{2}ds\right)^{\nicefrac{1}{2}}=\left(\intop_{0}^{\infty}\left|\intop_{0}^{1}f\left(st\right)dt\right|^{2}ds\right)^{\nicefrac{1}{2}}\\
 & \leq\left(\intop_{0}^{\infty}\left(\intop_{0}^{1}\left|f\left(st\right)\right|dt\right)^{2}ds\right)^{\nicefrac{1}{2}}\leq\intop_{0}^{1}\left(\intop_{0}^{\infty}\left|f\left(st\right)\right|^{2}ds\right)^{\nicefrac{1}{2}}dt\\
 & =\intop_{0}^{1}\left(\frac{1}{s}\intop_{0}^{\infty}\left|f\left(u\right)\right|^{2}du\right)^{\nicefrac{1}{2}}dt=\intop_{0}^{1}s^{-\nicefrac{1}{2}}dt\left\Vert f\right\Vert _{2}=2\left\Vert f\right\Vert _{2}
\end{align*}

\end_inset

ומשרירותיות 
\begin_inset Formula $f$
\end_inset

