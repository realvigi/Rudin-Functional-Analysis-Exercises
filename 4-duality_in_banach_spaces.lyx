\begin_inset Formula $c^{*}$
\end_inset

 על 
\begin_inset Formula $\ell^{1}$
\end_inset

 כנדרש.
\end_layout

\end_deeper
\begin_layout Enumerate
יהא 
\begin_inset Formula $x^{*}\in c^{*}$
\end_inset

.
 אז לכל 
\begin_inset Formula $x\in c_{0}$
\end_inset

 מתקיים
\begin_inset Formula 
\[
\left\langle x,S^{*}x^{*}\right\rangle =\left\langle Sx,x^{*}\right\rangle =\left\langle x,x^{*}\right\rangle 
\]

\end_inset

כלומר 
\begin_inset Formula $S^{*}x^{*}$
\end_inset

 הוא פשוט הצמצום של 
\begin_inset Formula $x^{*}$
\end_inset

 ל-
\begin_inset Formula $c_{0}$
\end_inset

.
\begin_inset Newline newline
\end_inset

כפי שראינו בסעיף הקודם, אם 
\begin_inset Formula $y\in\ell^{1}$
\end_inset

 אז לכל 
\begin_inset Formula $x\in c$
\end_inset

 מתקיים
\begin_inset Formula 
\begin{align*}
\left\langle x,u^{-1}\left(y\right)\right\rangle  & =x_{\infty}\sum_{n=1}^{\infty}y\left(n\right)+\sum_{n=1}^{\infty}\left(x\left(n\right)-x_{\infty}\right)y\left(n+1\right)
\end{align*}

\end_inset

ולכן לכל 
\begin_inset Formula $x\in c_{0}$
\end_inset

 נקבל
\begin_inset Formula 
\[
\left\langle x,S^{*}u^{-1}\left(y\right)\right\rangle =\left\langle x,u^{-1}\left(y\right)\right\rangle =\sum_{n=1}^{\infty}x\left(n\right)y\left(n+1\right)
\]

\end_inset

ולכן לכל 
\begin_inset Formula $k$
\end_inset

 נקבל
\begin_inset Formula 
\[
vS^{*}u^{-1}\left(y\right)\left(k\right)=\left\langle e_{k},S^{*}u^{-1}\left(y\right)\right\rangle =y\left(k+1\right)
\]

\end_inset

כלומר 
\begin_inset Formula $vS^{*}u^{-1}$
\end_inset

 הוא אופרטור ההזזה שמאלה.
\end_layout

\begin_layout Enumerate
ברור ש-
\begin_inset Formula $T$
\end_inset

 לינארי.
\begin_inset Newline newline
\end_inset

אם 
\begin_inset Formula $Tx=0$
\end_inset

, אז 
\begin_inset Formula $x_{\infty}=0$
\end_inset

 וגם 
\begin_inset Formula $x\left(n\right)-x_{\infty}=0$
\end_inset

 לכל 
\begin_inset Formula $n$
\end_inset

, ולכן 
\begin_inset Formula $x=0$
\end_inset

.
 אז 
\begin_inset Formula $T$
\end_inset

 חח
\begin_inset Quotes erd
\end_inset

ע.
\begin_inset Newline newline
\end_inset

כמו כן אם 
\begin_inset Formula $x_{0}\in c_{0}$
\end_inset

 ונגדיר 
\begin_inset Formula $x\left(n\right)=x_{0}\left(n+1\right)+x_{0}\left(1\right)$
\end_inset

, אז 
\begin_inset Formula $x\left(n\right)\rightarrow x_{0}\left(1\right)$
\end_inset

 ולכן 
\begin_inset Formula $x\in c$
\end_inset

 ו-
\begin_inset Formula $Tx\left(1\right)=x_{\infty}=x_{0}\left(1\right)$
\end_inset

 ולכל 
\begin_inset Formula $n\geq1$
\end_inset

 מתקיים
\begin_inset Formula 
\[
Tx\left(n+1\right)=x\left(n\right)-x_{\infty}=x_{0}\left(n+1\right)+x_{0}\left(1\right)-x_{0}\left(1\right)=x_{0}\left(n+1\right)
\]

\end_inset

ולכן 
\begin_inset Formula $Tx=x_{0}$
\end_inset

.
 אז אכן 
\begin_inset Formula $T\left(c\right)=c_{0}$
\end_inset

 כנדרש.
\begin_inset Newline newline
\end_inset

לכל 
\begin_inset Formula $x\in c$
\end_inset

 מתקיים
\begin_inset Formula 
\[
\left\Vert Tx\right\Vert _{\infty}=\max\left\{ \left|x_{\infty}\right|,\left\Vert x-x_{\infty}\right\Vert _{\infty}\right\} \leq2\left\Vert x\right\Vert _{\infty}
\]

\end_inset

כלומר 
\begin_inset Formula $\left\Vert T\right\Vert \leq2$
\end_inset

.
\begin_inset Newline newline
\end_inset

מצד שני אם 
\begin_inset Formula $x\left(1\right)=-1$
\end_inset

 ו-
\begin_inset Formula $x\left(n\right)=1$
\end_inset

 לכל 
\begin_inset Formula $n\geq2$
\end_inset

 אז 
\begin_inset Formula $\left\Vert x\right\Vert \leq1$
\end_inset

 וגם
\begin_inset Formula 
\[
Tx\left(2\right)=x_{1}-x_{\infty}=-1-1=-2
\]

\end_inset

ולכן 
\begin_inset Formula $\left\Vert Tx\right\Vert _{\infty}\geq2$
\end_inset

.
 אז 
\begin_inset Formula $\left\Vert T\right\Vert \geq2$
\end_inset

.
 אז 
\begin_inset Formula $\left\Vert T\right\Vert =2$
\end_inset

.
\begin_inset Newline newline
\end_inset

כפי שראינו קודם, 
\begin_inset Formula $T^{-1}x_{0}\left(n\right)=x_{0}\left(n+1\right)+x_{0}\left(1\right)$
\end_inset

 לכל 
\begin_inset Formula $x_{0}\in c_{0}$
\end_inset

 ולכל 
\begin_inset Formula $n\geq1$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז 
\begin_inset Formula $\left\Vert T^{-1}x_{0}\right\Vert _{\infty}\leq2\left\Vert x_{0}\right\Vert _{\infty}$
\end_inset

 ומצד שני 
\begin_inset Formula $T^{-1}\left(e_{1}+e_{2}\right)\left(1\right)=2$
\end_inset

 ו-
\begin_inset Formula $\left\Vert e_{1}+e_{2}\right\Vert _{\infty}=1$
\end_inset

, ולכן 
\begin_inset Formula $\left\Vert T^{-1}\right\Vert \geq2$
\end_inset

.
 אז 
\begin_inset Formula $\left\Vert T^{-1}\right\Vert =2$
\end_inset

.
\begin_inset Newline newline
\end_inset

נקבע 
\begin_inset Formula $y\in\ell^{1}$
\end_inset

.
 לכל 
\begin_inset Formula $x_{0}\in c_{0}$
\end_inset

 מתקיים
\begin_inset Formula 
\[
\left\langle x_{0},v^{-1}y\right\rangle =\sum_{n=1}^{\infty}x_{0}\left(n\right)y\left(n\right)
\]

\end_inset

ואז לכל 
\begin_inset Formula $x\in c$
\end_inset

 מתקיים
\begin_inset Formula 
\begin{align*}
\left\langle x,T^{*}v^{-1}y\right\rangle  & =\sum_{n=1}^{\infty}Tx\left(n\right)y\left(n\right)\\
 & =Tx\left(1\right)y\left(1\right)+\sum_{n=1}^{\infty}Tx\left(n+1\right)y\left(n+1\right)\\
 & =x_{\infty}y\left(1\right)+\sum_{n=1}^{\infty}\left(x\left(n\right)-x_{\infty}\right)y\left(n+1\right)
\end{align*}

\end_inset

ובפרט מתקיים 
\begin_inset Formula $\left\langle 1,T^{*}v^{-1}y\right\rangle =y\left(1\right)$
\end_inset

 ולכל 
\begin_inset Formula $k$
\end_inset

 מתקיים
\begin_inset Formula 
\[
\left\langle e_{k},T^{*}v^{-1}y\right\rangle =y\left(k+1\right)
\]

\end_inset

ולכן לכל 
\begin_inset Formula $k\geq2$
\end_inset


\begin_inset Formula 
\begin{align*}
uT^{*}v^{-1}y\left(1\right) & =\left\langle 1,T^{*}v^{-1}y\right\rangle -\sum_{n=1}^{\infty}\left\langle e_{k},T^{*}v^{-1}y\right\rangle =y\left(1\right)-\sum_{n=1}^{\infty}y\left(k+1\right)\\
uT^{*}v^{-1}y\left(k\right) & =\left\langle e_{k-1},T^{*}v^{-1}y\right\rangle =y\left(k\right)
\end{align*}

\end_inset

כלומר 
\begin_inset Formula $uT^{*}v^{-1}$
\end_inset

 הוא אופרטור שמחסר מהקואודינאטה הראשונה את הסכום של כל שאר הקואורדינאטות,
 ואת כל שאר הקואורדינאטות הוא לא משנה בכלל.
\end_layout

\end_deeper
\begin_layout Enumerate
המאפס של תת-מרחב של 
\begin_inset Formula $X$
\end_inset

 הוא תמיד סגור חלש
\begin_inset Formula $^{*}$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז 
\begin_inset Formula $\mathcal{N}\left(T\right)^{\perp}$
\end_inset

 סגור חלש
\begin_inset Formula $^{*}$
\end_inset

 ולכן 
\begin_inset Formula $\mathcal{R}\left(T^{*}\right)$
\end_inset

 סגור חלש
\begin_inset Formula $^{*}$
\end_inset

.
\begin_inset Newline newline
\end_inset

אבל 
\begin_inset Formula $\mathcal{R}\left(T^{*}\right)$
\end_inset

 סגור חלש
\begin_inset Formula $^{*}$
\end_inset

 אם
\begin_inset Quotes erd
\end_inset

ם 
\begin_inset Formula $\mathcal{R}\left(T\right)$
\end_inset

 סגור ב-
\begin_inset Formula $Y$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז אכן 
\begin_inset Formula $\mathcal{R}\left(T\right)$
\end_inset

 סגור ב-
\begin_inset Formula $Y$
\end_inset

 כנדרש.
\end_layout

\begin_layout Enumerate
יהיו 
\begin_inset Formula $U,V$
\end_inset

 כדורי היחידה בפתוחים ב-
\begin_inset Formula $X,Y$
\end_inset

 בהתאמה.
\begin_inset Newline newline
\end_inset

מכך ש-
\begin_inset Formula $T\left(X\right)=Y$
\end_inset

, קיים 
\begin_inset Formula $\delta>0$
\end_inset

 עבורו 
\begin_inset Formula $\left\Vert T^{*}y^{*}\right\Vert \geq2\delta\left\Vert y^{*}\right\Vert $
\end_inset

 לכל 
\begin_inset Formula $y^{*}\in Y^{*}$
\end_inset

.
\begin_inset Newline newline
\end_inset

יהא 
\begin_inset Formula $S\in\kaliBBasis\left(X,Y\right)$
\end_inset

 עבורו 
\begin_inset Formula $\left\Vert S-T\right\Vert <\delta$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז לכל 
\begin_inset Formula $y^{*}\in Y^{*}$
\end_inset

 מתקיים
\begin_inset Formula 
\begin{align*}
\left\Vert \left(S-T\right)^{*}y^{*}\right\Vert  & =\sup_{\left\Vert x\right\Vert \leq1}\left|\left\langle x,\left(S-T\right)^{*}y^{*}\right\rangle \right|\\
 & =\sup_{\left\Vert x\right\Vert \leq1}\left|\left\langle \left(S-T\right)x,y^{*}\right\rangle \right|\\
 & \leq\sup_{\left\Vert x\right\Vert \leq1}\left\Vert \left(S-T\right)x\right\Vert \left\Vert y^{*}\right\Vert \\
 & \leq\left\Vert S-T\right\Vert \left\Vert y^{*}\right\Vert <\delta\left\Vert y^{*}\right\Vert 
\end{align*}

\end_inset

ולכן לכל 
\begin_inset Formula $y^{*}\in Y^{*}$
\end_inset

 מתקיים
\begin_inset Newline newline
\end_inset


\begin_inset Formula 
\begin{align*}
\left\Vert S^{*}y^{*}\right\Vert  & =\left\Vert T^{*}y^{*}+\left(S-T\right)^{*}y^{*}\right\Vert \geq\left\Vert T^{*}y^{*}\right\Vert -\left\Vert \left(S-T\right)^{*}y^{*}\right\Vert \\
 & \geq2\delta\left\Vert y^{*}\right\Vert -\left\Vert \left(S-T\right)^{*}y^{*}\right\Vert >\delta\left\Vert y^{*}\right\Vert 
\end{align*}

\end_inset

ולכן 
\begin_inset Formula $S\left(X\right)=Y$
\end_inset

 כנדרש.
\end_layout

\begin_layout Enumerate
נניח שקיימת סדרה 
\begin_inset Formula $\left\{ x_{n}\right\} $
\end_inset

 עבורה 
\begin_inset Formula $\left\Vert x_{n}\right\Vert =1$
\end_inset

 לכל 
\begin_inset Formula $n$
\end_inset

 ו-
\begin_inset Formula $\left\Vert Tx_{n}-\lambda x_{n}\right\Vert \rightarrow0$
\end_inset

 ונראה 
\begin_inset Formula $\lambda\in\sigma\left(T\right)$
\end_inset

.
\begin_inset Newline newline
\end_inset

אם 
\begin_inset Formula $\left(T-\lambda I\right)\left(X\right)\neq X$
\end_inset

, אז סיימנו.
\begin_inset Newline newline
\end_inset

אז נניח 
\begin_inset Formula $\left(T-\lambda I\right)\left(X\right)=X$
\end_inset

.
 יהא 
\begin_inset Formula $U$
\end_inset

 כדור היחידה הפתוח.
\begin_inset Newline newline
\end_inset

אז יש 
\begin_inset Formula $\delta>0$
\end_inset

 עבורו 
\begin_inset Formula $\delta U\subseteq\left(T-\lambda I\right)\left(U\right)$
\end_inset

.
\begin_inset Newline newline
\end_inset

קיים 
\begin_inset Formula $n$
\end_inset

 גדול מספיק עבורו 
\begin_inset Formula $\left\Vert Tx_{n}-\lambda x_{n}\right\Vert <\delta$
\end_inset

, ואז 
\begin_inset Formula $\left(T-\lambda I\right)x_{n}\in T\left(U\right)$
\end_inset

.
\begin_inset Newline newline
\end_inset

אבל 
\begin_inset Formula $x_{n}\notin U$
\end_inset

, ולכן 
\begin_inset Formula $T-\lambda I$
\end_inset

 לא חח
\begin_inset Quotes erd
\end_inset

ע ולכן 
\begin_inset Formula $\lambda\in\sigma\left(T\right)$
\end_inset

 וסיימנו.
\begin_inset Newline newline
\end_inset

הכיוון השני לא נכון באופן כללי.
\begin_inset Newline newline
\end_inset

למשל, אם ניקח 
\begin_inset Formula $X=\ell^{2}$
\end_inset

 ו-
\begin_inset Formula $T$
\end_inset

 אופרטור ההזזה ימינה, כלומר 
\begin_inset Formula $Tx\left(n\right)=x\left(n-1\right)$
\end_inset

 אם 
\begin_inset Formula $n\geq2$
\end_inset

 ו-
\begin_inset Formula $Tx\left(1\right)=0$
\end_inset

, אז 
\begin_inset Formula $T$
\end_inset

 איזומטריה לינארית ובפרט 
\begin_inset Formula $T\in\kaliBBasis\left(X\right)$
\end_inset

.
\begin_inset Newline newline
\end_inset


\begin_inset Formula $T$
\end_inset

 לא על, ולכן 
\begin_inset Formula $0\in\sigma\left(T\right)$
\end_inset

, אבל מכך ש-
\begin_inset Formula $T$
\end_inset

 איזומטריה, לא קיימת סדרה 
\begin_inset Formula $\left\{ x_{n}\right\} $
\end_inset

 שמקיימת גם 
\begin_inset Formula $\left\Vert x_{n}\right\Vert =1$
\end_inset

 לכל 
\begin_inset Formula $n$
\end_inset

 וגם 
\begin_inset Formula $\left\Vert Tx_{n}\right\Vert \rightarrow0$
\end_inset

, בסתירה למה שצריך להוכיח.
\end_layout

