\begin{align*}
\left\Vert Tf_{n}-Tf_{m}\right\Vert _{2}^{2} & =\intop_{0}^{\infty}\left|Tf_{n}\left(s\right)-Tf_{m}\left(s\right)\right|^{2}ds\geq\intop_{m^{2}}^{\infty}\left|\frac{n}{s}-\frac{m}{s}\right|^{2}ds\\
 & =\left(m-n\right)^{2}\intop_{m^{2}}^{\infty}\frac{1}{s^{2}}ds=\frac{\left(m-n\right)^{2}}{m^{2}}=\left(1-\frac{n}{m}\right)^{2}
\end{align*}

\end_inset

