\end_inset

 הנתונה ע
\begin_inset Quotes erd
\end_inset

י 
\begin_inset Formula $\Psi\left(x\right)y=\sum_{n=1}^{\infty}x\left(n\right)y\left(n\right)$
\end_inset

 גם היא איזומורפיזם איזומטרי.
\begin_inset Newline newline
\end_inset

תהא 
\begin_inset Formula $\phi:\ell^{p}\rightarrow\left(\ell^{p}\right)^{**}$
\end_inset

 השיכון הקנוני.
\begin_inset Newline newline
\end_inset

אז לכל 
\begin_inset Formula $x\in\ell^{p}$
\end_inset

, ולכל 
\begin_inset Formula $x^{*}\in\left(\ell^{p}\right)^{*}$
\end_inset

 מתקיים
\begin_inset Formula 
\begin{align*}
\left\langle x^{*},\left(\Phi^{-1}\right)^{*}\Psi x\right\rangle  & =\left\langle \Phi^{-1}x^{*},\Psi x\right\rangle =\sum_{n=1}^{\infty}x\left(n\right)\left(\Phi^{-1}x^{*}\right)\left(n\right)\\
 & =\left\langle x,\Phi\left(\Phi^{-1}x^{*}\right)\right\rangle =\left\langle x,x^{*}\right\rangle =\left\langle x^{*},\phi x\right\rangle 
\end{align*}

\end_inset

ולכן 
\begin_inset Formula $\phi=\left(\Phi^{-1}\right)^{*}\circ\Psi$
\end_inset

 ובפרט 
\begin_inset Formula 
\[
\phi\left(\ell^{p}\right)=\left(\Phi^{-1}\right)^{*}\left(\Psi\left(\ell^{p}\right)\right)=\left(\Phi^{-1}\right)^{*}\left(\left(\ell^{q}\right)^{*}\right)=\left(\ell^{p}\right)^{**}
\]

\end_inset

