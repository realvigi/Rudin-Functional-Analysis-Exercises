\begin_inset Formula 
\[
\limsup_{\delta\rightarrow0}\delta^{-\alpha}\omega_{\delta}\left(f+g\right)\leq\limsup_{\delta\rightarrow0}\delta^{-\alpha}\left(\omega_{\delta}\left(f\right)+\omega_{\delta}\left(g\right)\right)=0
\]

\end_inset

ומצד שני 
\begin_inset Formula $\delta^{-\alpha}\omega_{\delta}\left(f+g\right)\geq0$
\end_inset

 לכל 
\begin_inset Formula $\delta>0$
\end_inset

, ולכן נקבל 
\begin_inset Formula $\delta^{-\alpha}\omega_{\delta}\left(f+g\right)\xrightarrow[\delta\rightarrow0]{}0$
\end_inset

 כלומר 
\begin_inset Formula $f+g\in\text{lip}\alpha$
\end_inset

.
\begin_inset Newline newline
\end_inset

כמו כן 
\begin_inset Formula $\delta^{-\alpha}\omega_{\delta}\left(\lambda f\right)=\left|\lambda\right|\delta^{-\alpha}\omega_{\delta}\left(f\right)\xrightarrow[\delta\rightarrow0]{}\left|\lambda\right|\cdot0=0$
\end_inset

 ולכן 
\begin_inset Formula $\lambda f\in\text{lip}\alpha$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז 
\begin_inset Formula $\text{lip}\alpha$
\end_inset

 אכן תת-מרחב של 
\begin_inset Formula $\text{Lip}\alpha$
\end_inset

.
 נוכיח שהוא סגור.
\begin_inset Newline newline
\end_inset

תהא 
\begin_inset Formula $\left\{ f_{n}\right\} $
\end_inset

 סדרה ב-
\begin_inset Formula $\text{lip}\alpha$
\end_inset

, ונניח 
\begin_inset Formula $\left\Vert f_{n}-f\right\Vert \rightarrow0$
\end_inset

 עבור 
\begin_inset Formula $f\in\text{Lip}\alpha$
\end_inset

 כלשהי.
\begin_inset Newline newline
\end_inset

יהא 
\begin_inset Formula $\varepsilon>0$
\end_inset

.
 אז 
\begin_inset Formula $n$
\end_inset

 גדול מספיק עבורו מתקיים 
\begin_inset Formula $\left\Vert f_{n}-f\right\Vert <\nicefrac{\varepsilon}{2}$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז לכל 
\begin_inset Formula $\delta>0$
\end_inset

 מתקיים 
\begin_inset Formula $\delta^{-\alpha}\omega_{\delta}\left(f_{n}-f\right)<\nicefrac{\varepsilon}{2}$
\end_inset

, ולכן לכל 
\begin_inset Formula $\delta>0$
\end_inset

 ולכל 
\begin_inset Formula $x,y\in I$
\end_inset

 עם 
\begin_inset Formula $\left|x-y\right|<\delta$
\end_inset

 מתקיים 
\begin_inset Formula 
\[
\delta^{-\alpha}\left|f_{n}\left(x\right)-f\left(x\right)-\left(f_{n}\left(y\right)-f\left(y\right)\right)\right|<\frac{\varepsilon}{2}
\]

\end_inset

ובנוסף מתקיים 
\begin_inset Formula $\omega_{\delta}\left(f_{n}\right)\xrightarrow[\delta\rightarrow0]{}0$
\end_inset


\begin_inset Formula $\delta^{-\alpha}$
\end_inset

 לכןאז קיים 
\begin_inset Formula $r>0$
\end_inset

 עבורו לכל 
\begin_inset Formula $\delta\in\left(0,r\right)$
\end_inset

 מתקיים 
\begin_inset Formula $\delta^{-\alpha}\omega_{\delta}\left(f_{n}\right)<\nicefrac{\varepsilon}{2}$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז 
\begin_inset Formula $\delta\in\left(0,r\right)$
\end_inset

, ולכל 
\begin_inset Formula $x,y\in I$
\end_inset

 עם 
\begin_inset Formula $\left|x-y\right|<\delta$
\end_inset


\begin_inset Formula 
\begin{align*}
\left|f\left(x\right)-f\left(y\right)\right| & \leq\left|f_{n}\left(x\right)-f_{n}\left(y\right)-\left(f\left(x\right)-f\left(y\right)\right)\right|+\left|f_{n}\left(x\right)-f_{n}\left(y\right)\right|\\
 & =\left|f_{n}\left(x\right)-f\left(x\right)-\left(f_{n}\left(y\right)-f\left(y\right)\right)\right|+\left|f_{n}\left(x\right)-f_{n}\left(y\right)\right|\\
 & <\frac{\delta^{\alpha}\varepsilon}{2}+\frac{\delta^{\alpha}\varepsilon}{2}=\delta^{\alpha}\varepsilon
\end{align*}

\end_inset

ולכן לכל 
\begin_inset Formula $\delta\in\left(0,r\right)$
\end_inset

 נקבל 
\begin_inset Formula $\omega_{\delta}\left(f\right)<\delta^{\alpha}\varepsilon$
\end_inset

, כלומר 
\begin_inset Formula $\delta^{-\alpha}\omega_{\delta}\left(f\right)<\varepsilon$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז אכן 
\begin_inset Formula $\delta^{-\alpha}\omega_{\delta}\left(f\right)\xrightarrow[\delta\rightarrow0]{}0$
\end_inset

, ולכן 
\begin_inset Formula $f\in\text{lip}\alpha$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז כל גבול של סדרה ב-
\begin_inset Formula $\text{lip}\alpha$
\end_inset

 נמצא ב-
\begin_inset Formula $\text{lip}\alpha$
\end_inset

, ומכך ש-
\begin_inset Formula $\text{Lip}\alpha$
\end_inset

 מרחב נורמי )ובפרט מטרי( נקבל ש-
\begin_inset Formula $\text{lip}\alpha$
\end_inset

 קבוצה סגורה כנדרש.
