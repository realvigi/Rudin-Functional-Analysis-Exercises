\begin_inset Quotes erd
\end_inset

י 
\begin_inset Formula $\mathcal{L}$
\end_inset

 היא פתוחה גם בטופולוגיה שמשרה 
\begin_inset Formula $\mathcal{P}$
\end_inset

.
 אז אכן שתי הטופולוגיות זהות.
\begin_inset Newline newline
\end_inset

נראה שההזזות של הקבוצות 
\begin_inset Formula $V\left(p,n\right)$
\end_inset

 עבור 
\begin_inset Formula $p\in\mathcal{L},n\in\kaliNatural$
\end_inset

 הן למעשה בסיס לטופולוגיה הזאת.
\begin_inset Newline newline
\end_inset

נתחיל מלהראות שהקבוצות 
\begin_inset Formula $V\left(p,n\right)$
\end_inset

 עבור 
\begin_inset Formula $p\in\mathcal{L},n\in\kaliNatural$
\end_inset

 מהוות בסיס מקומי עבור הטופולוגיה.
 ברור שהן כולן סביבות פתוחות של 
\begin_inset Formula $0$
\end_inset

.
\begin_inset Newline newline
\end_inset

כמו כן אם 
\begin_inset Formula $U$
\end_inset

 היא סביבה פתוחה כלשהי של 
\begin_inset Formula $0$
\end_inset

, אז יש 
\begin_inset Formula $p_{1},\ldots,p_{k}\in\mathcal{P},n_{1},\ldots,n_{k}\in\kaliNatural$
\end_inset

 עבורם
\begin_inset Formula 
\[
\bigcap_{1\leq i\leq k}V\left(p_{i},n_{i}\right)\subseteq U
\]

\end_inset

לכן
\begin_inset Formula 
\begin{align*}
V\left(\max_{1\leq i\leq k}p_{i},\max_{1\leq i\leq k}n_{i}\right) & =\left\{ x:\max_{1\leq i\leq k}p_{i}\left(x\right)\leq\left(\max_{1\leq i\leq k}n_{i}\right)^{-1}\right\} \\
 & =\left\{ x:\max_{1\leq i\leq k}p_{i}\left(x\right)\leq\min_{1\leq i\leq k}n_{i}^{-1}\right\} \\
 & \subseteq\left\{ x:p_{1}\leq n_{1}^{-1},\ldots,p_{k}\leq n_{k}^{-1}\right\} \\
 & =\bigcap_{1\leq i\leq k}V\left(p_{i},n_{i}\right)\subseteq U
\end{align*}

\end_inset

