 פונקציות ולכל סקלר 
\begin_inset Formula $\lambda$
\end_inset

 מתקיים, ולכל 
\begin_inset Formula $\delta>0$
\end_inset

 מתקיים
\begin_inset Formula 
\begin{align*}
\omega_{\delta}\left(f+g\right) & =\sup\left\{ \left|f\left(x\right)+g\left(x\right)-f\left(y\right)-g\left(y\right)\right|:\left|x-y\right|\leq\delta\right\} \\
 & \leq\sup\left\{ \left|f\left(x\right)-f\left(y\right)\right|+\left|g\left(x\right)-g\left(y\right)\right|:\left|x-y\right|\leq\delta\right\} \\
 & \leq\sup\left\{ \left|f\left(x\right)-f\left(y\right)\right|:\left|x-y\right|\leq\delta\right\} +\sup\left\{ \left|g\left(x\right)-g\left(y\right)\right|:\left|x-y\right|\leq\delta\right\} \\
 & =\omega_{\delta}\left(f\right)+\omega_{\delta}\left(g\right)\\
\omega_{\delta}\left(\lambda f\right) & =\sup\left\{ \left|\lambda f\left(x\right)-\lambda f\left(y\right)\right|:\left|x-y\right|\leq\delta\right\} \\
 & =\left|\lambda\right|\sup\left\{ \left|f\left(x\right)-f\left(y\right)\right|:\left|x-y\right|\leq\delta\right\} =\left|\lambda\right|\omega_{\delta}\left(f\right)
\end{align*}

\end_inset

ולכן
\begin_inset Formula 
\begin{align*}
\left\Vert f+g\right\Vert  & =\left|f\left(0\right)+g\left(0\right)\right|+\sup\left\{ \delta^{-\alpha}\omega_{\delta}\left(f+g\right):\delta>0\right\} \\
 & \leq\left|f\left(0\right)\right|+\left|g\left(0\right)\right|+\sup\left\{ \delta^{-\alpha}\omega_{\delta}\left(f\right)+\delta^{-\alpha}\omega_{\delta}\left(g\right):\delta>0\right\} \\
 & \leq\left|f\left(0\right)\right|+\sup\left\{ \delta^{-\alpha}\omega_{\delta}\left(f\right):\delta>0\right\} +\left|g\left(0\right)\right|+\sup\left\{ \delta^{-\alpha}\omega_{\delta}\left(g\right):\delta>0\right\} \\
 & =\left\Vert f\right\Vert +\left\Vert g\right\Vert \\
\left\Vert \lambda f\right\Vert  & =\left|\lambda f\left(0\right)\right|+\sup\left\{ \delta^{-\alpha}\omega_{\delta}\left(\lambda f\right):\delta>0\right\} \\
 & =\left|\lambda\right|\left|f\left(0\right)\right|+\left|\lambda\right|\sup\left\{ \delta^{-\alpha}\omega_{\delta}\left(f\right):\delta>0\right\} \\
 & =\left|\lambda\right|\left(\left|f\left(0\right)\right|+\sup\left\{ \delta^{-\alpha}\omega_{\delta}\left(f\right):\delta>0\right\} \right)=\left|\lambda\right|\left\Vert f\right\Vert 
\end{align*}

\end_inset

ולכן 
\begin_inset Formula $f,g\in\text{Lip}\alpha$
\end_inset

 מתקיים 
\begin_inset Formula $f+g,\lambda f\in\text{Lip}\alpha$
\end_inset

.
