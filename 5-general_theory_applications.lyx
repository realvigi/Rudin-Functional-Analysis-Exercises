\begin{align*}
\mu_{1}\left(E\right) & =2\left(m\left(E\cap\left[\frac{1}{2},1\right]\right)-m\left(E\cap\left[0,\frac{1}{2}\right]\right)\right)\\
\mu_{2}\left(E\right) & =2\left(m\left(E\cap\left(\left[0,\frac{1}{4}\right]\cup\left[\frac{3}{4},1\right]\right)\right)-m\left(E\cap\left[\frac{1}{4},\frac{3}{4}\right]\right)\right)
\end{align*}

\end_inset

נקבע 
\begin_inset Formula $E$
\end_inset

 כזו.
 נסמן 
\begin_inset Formula $\alpha_{i}=m\left(E\cap\left[\nicefrac{\left(i-1\right)}{4},\nicefrac{i}{4}\right]\right)$
\end_inset

