\end_inset

.
\begin_inset Newline newline
\end_inset

אז נקבל
\begin_inset Formula 
\begin{align*}
\mu_{1}\left(E\right) & =2\left(\alpha_{4}-\alpha_{2}+\alpha_{3}-\alpha_{1}\right)\\
\mu_{2}\left(E\right) & =2\left(\alpha_{4}-\alpha_{2}-\left(\alpha_{3}-\alpha_{1}\right)\right)
\end{align*}

\end_inset

ולכן אם נסמן 
\begin_inset Formula $p=\alpha_{4}-\alpha_{2},q=\alpha_{3}-\alpha_{1}$
\end_inset

 אז
\begin_inset Formula 
\[
\left|\mu_{1}\left(E\right)\right|+\left|\mu_{2}\left(E\right)\right|=2\left(\left|p+q\right|+\left|p-q\right|\right)
\]

\end_inset

מתקיים
\begin_inset Formula 
\[
\left|p+q\right|+\left|p-q\right|=\begin{cases}
2p & p\geq q,p\geq-q\\
-2q & p\geq q,p<-q\\
2q & p<q,p\geq-q\\
-2p & p<q,p<-q
\end{cases}
\]

\end_inset

ולכן בכל מקרה
\begin_inset Formula 
\[
\left|p+q\right|+\left|p-q\right|\leq2\max\left\{ \left|p\right|,\left|q\right|\right\} 
\]

\end_inset

ולכן
\begin_inset Formula 
\[
\left|\mu_{1}\left(E\right)\right|+\left|\mu_{2}\left(E\right)\right|=4\max\left\{ \left|\alpha_{4}-\alpha_{2}\right|,\left|\alpha_{3}-\alpha_{1}\right|\right\} 
\]

\end_inset

אבל 
\begin_inset Formula $0\leq\alpha_{1},\alpha_{2},\alpha_{2},\alpha_{4}\leq\nicefrac{1}{4}$
