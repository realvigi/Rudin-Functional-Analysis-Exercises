\left|B\left(g_{n}-f_{n},f_{n}\right)\right| & \leq\intop_{0}^{1}\left|g_{n}\left(t\right)-f_{n}\left(t\right)\right|\left|f_{n}\left(t\right)\right|dt\leq2^{-n}n\\
B\left(f_{n},f_{n}\right) & =\intop_{0}^{1}\left(f_{n}\left(t\right)\right)^{2}dt\geq\intop_{0}^{n^{-2}}n^{2}dt=1
\end{align*}

