\begin{align*}
\left\Vert g_{n}\right\Vert  & \leq\left\Vert g_{n}-f_{n}\right\Vert +\left\Vert f_{n}\right\Vert =\intop_{0}^{1}\left|g_{n}\left(t\right)-f_{n}\left(t\right)\right|dt+\intop_{0}^{1}\left|f_{n}\left(t\right)\right|dt\\
 & \leq2^{-n}+\intop_{0}^{n^{-2}+2^{-n}}ndt=2^{-n}+n^{-1}+2^{-n}n\xrightarrow[n\rightarrow\infty]{}0
\end{align*}

\end_inset

ולכן 
\begin_inset Formula $g_{n}\rightarrow0$
\end_inset

 ב-
\begin_inset Formula $X$
