תהא 
\begin_inset Formula $\left\{ x_{k}\right\} $
\end_inset

 סדרה ב-
\begin_inset Formula $E$
\end_inset

, ונניח שיש 
\begin_inset Formula $x\in\ell^{q}$
\end_inset

 כך ש-
\begin_inset Formula $\left\Vert x_{k}-x\right\Vert _{q}\rightarrow0$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז יש תת-סדרה 
\begin_inset Formula $\left\{ x_{k_{j}}\right\} $
\end_inset

 עבורה 
\begin_inset Formula $x_{k_{j}}\xrightarrow[j\rightarrow\infty]{}x$
\end_inset

 נקודתית כמעט בכל מקום, ביחס למידת המניה על 
\begin_inset Formula $\kaliNatural\cup\left\{ 0\right\} $
\end_inset

.
\begin_inset Newline newline
\end_inset

אז 
\begin_inset Formula $x_{k_{j}}\left(n\right)\xrightarrow[j\rightarrow\infty]{}x\left(n\right)$
\end_inset

 לכל 
\begin_inset Formula $n\geq0$
\end_inset

.
\begin_inset Newline newline
\end_inset

מהלמה של פאטו נקבל
\begin_inset Formula 
\begin{align*}
\left\Vert x\right\Vert _{p}^{p} & =\sum_{n=0}^{\infty}\left|x\left(n\right)\right|^{p}=\sum_{n=0}^{\infty}\left(\liminf_{j\rightarrow\infty}\left|x_{k_{j}}\left(n\right)\right|\right)^{p}\\
 & \leq\liminf_{j\rightarrow\infty}\sum_{n=0}^{\infty}\left(\left|x_{k_{j}}\left(n\right)\right|\right)^{p}=\liminf_{j\rightarrow\infty}\left\Vert x_{k_{j}}\right\Vert _{p}^{p}\\
 & \leq\liminf_{j\rightarrow\infty}M=M
\end{align*}

\end_inset

ולכן 
\begin_inset Formula $x\in E$
\end_inset

 כנדרש.
\begin_inset Newline newline
\end_inset

עכשיו נראה שהפנים של 
\begin_inset Formula $E$
\end_inset

 ריק.
\begin_inset Newline newline
\end_inset

נסמן 
\begin_inset Formula $y_{k}\left(n\right)=k^{-1}n^{-\nicefrac{1}{p}}$
\end_inset

לכל 
\begin_inset Formula $n\geq1$
\end_inset

, 
\begin_inset Formula $y_{k}\left(0\right)=0$
\end_inset

.
 
\begin_inset Newline newline
\end_inset

אז מכך ש-
\begin_inset Formula $p^{-1}q>1$
\end_inset

, לכל 
\begin_inset Formula $k$
\end_inset

 מתקיים
\begin_inset Formula 
\begin{align*}
\left\Vert y_{k}\right\Vert _{p}^{p} & =\frac{1}{k^{p}}\sum_{n=1}^{\infty}\frac{1}{n}=\infty\\
\left\Vert y_{k}\right\Vert _{q}^{q} & =\frac{1}{k^{q}}\sum_{n=1}^{\infty}\frac{1}{n^{\nicefrac{q}{p}}}<\infty
\end{align*}

\end_inset

כלומר 
\begin_inset Formula $y_{k}\in\ell^{q}\setminus\ell^{p}$
\end_inset

 לכל 
\begin_inset Formula $k$
\end_inset

.
\begin_inset Newline newline
\end_inset

עכשיו אם 
\begin_inset Formula $x\in E$
\end_inset

 נקודה כלשהי אז מתקיים
\begin_inset Formula 
\[
\left\Vert \left(x+y_{k}\right)-x\right\Vert _{q}=\left\Vert y_{k}\right\Vert _{q}=\left(\frac{1}{k^{q}}\sum_{n=1}^{\infty}\frac{1}{n^{\nicefrac{q}{p}}}\right)^{\nicefrac{1}{q}}=\frac{1}{k}\left\Vert y_{1}\right\Vert \xrightarrow[k\rightarrow\infty]{}0
\]

\end_inset

כלומר 
\begin_inset Formula $x+y_{k}\xrightarrow[k\rightarrow\infty]{}x$
\end_inset

 ב-
\begin_inset Formula $\ell^{q}$
\end_inset

.
\begin_inset Newline newline
\end_inset

מצד שני, לכל 
\begin_inset Formula $k$
\end_inset

 מתקיים 
\begin_inset Formula $x+y_{k}\notin\ell^{p}$
\end_inset

, כי אחרת 
\begin_inset Formula $y_{k}=\left(x+y_{k}\right)-x\in\ell^{p}$
\end_inset

 וראינו כבר שזה לא נכון.
\begin_inset Newline newline
\end_inset

אז בפרט 
\begin_inset Formula $x+y_{k}\notin E$
\end_inset

.
 כלומר מצאנו סדרה ב-
\begin_inset Formula $\ell^{q}$
\end_inset

, שכל האיברים שלה מחוץ ל-
\begin_inset Formula $E$
\end_inset

, שמתכנסת ל-
\begin_inset Formula $x$
\end_inset

.
 לכן 
\begin_inset Formula $x$
\end_inset

 לא נקודה פנימית.
\begin_inset Newline newline
\end_inset

אז ל-
\begin_inset Formula $E$
\end_inset

 אין נקודות פנימיות ולכן הפנים של 
\begin_inset Formula $E$
\end_inset

 ריק.
\begin_inset Newline newline
\end_inset

משרירותיות 
\begin_inset Formula $M$
\end_inset

, נקבל שכל הקבוצות 
\begin_inset Formula $E_{n}=\left\{ x\in\ell^{q}:\left\Vert x\right\Vert _{p}^{p}\leq n\right\} $
\end_inset

 הן סגורות עם פנים ריק ב-
\begin_inset Formula $\ell^{q}$
\end_inset

.
\begin_inset Newline newline
\end_inset

אבל 
\begin_inset Formula $\ell^{p}=\bigcup_{n}E_{n}$
\end_inset

 ולכן 
\begin_inset Formula $\ell^{p}$
\end_inset

 הוא מקטגוריה ראשונה ב-
\begin_inset Formula $\ell^{q}$
\end_inset

 כנדרש.
\end_layout

\begin_layout Enumerate
ראשית נניח 
\begin_inset Formula $1<p<q<\infty$
\end_inset

, ויהיו 
\begin_inset Formula $p^{*},q^{*}$
\end_inset

 האקספוננטים הצמודים ל-
\begin_inset Formula $p,q$
\end_inset

 בהתאמה.
\begin_inset Newline newline
\end_inset

אז 
\begin_inset Formula $1<q^{*}<p^{*}<\infty$
\end_inset

.
\begin_inset Newline newline
\end_inset

נקבע 
\begin_inset Formula $\alpha=\frac{1}{2}\left(\left(q^{*}\right)^{-1}+\left(p^{*}\right)^{-1}\right)$
\end_inset

 ולכל 
\begin_inset Formula $n,k$
\end_inset

 נגדיר
\begin_inset Formula 
\[
y_{k}\left(n\right)=\begin{cases}
k^{-\alpha} & n<k\\
0 & n\geq k
\end{cases}
\]

\end_inset

אז לכל 
\begin_inset Formula $k$
\end_inset

 מתקיים
\begin_inset Newline newline
\end_inset


\begin_inset Formula 
\begin{align*}
\left\Vert y_{k}\right\Vert _{p^{*}} & =\left(k\left|k^{-\alpha}\right|^{p^{*}}\right)^{\nicefrac{1}{p^{*}}}=k^{\nicefrac{1}{p^{*}}-\alpha}\\
\left\Vert y_{k}\right\Vert _{q^{*}} & =\left(k\left|a_{k}\right|^{q^{*}}\right)^{\nicefrac{1}{q^{*}}}=k^{\nicefrac{1}{q^{*}}-\alpha}
\end{align*}

\end_inset

ובפרט 
\begin_inset Formula $y_{k}\in\ell^{p^{*}},\ell^{q^{*}}$
\end_inset

 לכל 
\begin_inset Formula $k$
\end_inset

.
\begin_inset Newline newline
\end_inset

לכן 
\begin_inset Formula $y_{k}$
\end_inset

 משרה פונקציונלים לינאריים רציפים 
\begin_inset Formula $\Lambda_{k}^{p},\Lambda^{q}$
\end_inset

 על 
\begin_inset Formula $\ell^{p},\ell^{q}$
\end_inset

 בהתאמה, וכך שלכל 
\begin_inset Formula $x\in\ell^{p},x^{\prime}\in\ell^{q}$
\end_inset

 מתקיים 
\begin_inset Formula 
\begin{align*}
\Lambda_{k}^{p}x & =\sum_{n=0}^{\infty}x\left(n\right)y_{k}\left(n\right)\\
\Lambda_{k}^{q}x^{\prime} & =\sum_{n=0}^{\infty}x^{\prime}\left(n\right)y_{k}\left(n\right)
\end{align*}

\end_inset

ויתרה מזאת מתקיים 
\begin_inset Formula $\left\Vert \Lambda_{k}^{p}\right\Vert =\left\Vert y_{k}\right\Vert _{p},\left\Vert \Lambda_{k}^{q}\right\Vert =\left\Vert y_{k}\right\Vert _{q}$
\end_inset

.
\begin_inset Newline newline
\end_inset

נבחין שהצמצום של 
\begin_inset Formula $\Lambda_{k}^{q}$
\end_inset

 אל 
\begin_inset Formula $\ell^{p}$
\end_inset

 הוא בדיוק 
\begin_inset Formula $\Lambda_{k}^{p}$
\end_inset

.
\begin_inset Newline newline
\end_inset

כמו כן מתקיים 
\begin_inset Formula $\left(p^{*}\right)^{-1}-\alpha<0,\left(q^{*}\right)^{-1}-\alpha>0$
\end_inset

 ולכן 
\begin_inset Formula $\left\Vert y_{k}\right\Vert _{q^{*}}\rightarrow\infty,\left\Vert y_{k}\right\Vert _{p^{*}}\rightarrow0$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז 
\begin_inset Formula $\left\Vert \Lambda_{k}^{p}\right\Vert \rightarrow0$
\end_inset

, ולכן 
\begin_inset Formula $\Lambda_{k}^{p}x\rightarrow0$
\end_inset

 לכל 
\begin_inset Formula $x\in\ell^{p}$
\end_inset

, ולכן גם 
\begin_inset Formula $\Lambda_{k}^{q}x\rightarrow0$
\end_inset

 לכל 
\begin_inset Formula $x\in\ell^{p}$
\end_inset

.
\begin_inset Newline newline
\end_inset

מתקיים 
\begin_inset Formula $q^{-1}<\frac{1}{2}\left(q^{-1}+p^{-1}\right)$
\end_inset

, אבל חישוב פשוט נותן 
\begin_inset Formula $,\frac{1}{2}\left(q^{-1}+p^{-1}\right)=1-\alpha$
\end_inset

 ולכן נוכל לקבוע 
\begin_inset Formula $\beta\in\left(q^{-1},1-\alpha\right)$
\end_inset

.
\begin_inset Newline newline
\end_inset

נגדיר 
\begin_inset Formula $x\left(n\right)=n^{-\beta}$
\end_inset

 לכל 
\begin_inset Formula $n$
\end_inset

.
 אז מכך ש-
\begin_inset Formula $q\beta>1$
\end_inset

 לכל 
\begin_inset Formula $n$
\end_inset

 נקבל
\begin_inset Formula $\sum_{n=0}^{\infty}n^{-q\beta}<\infty$
\end_inset

.
\begin_inset Newline newline
\end_inset

כלומר 
\begin_inset Formula $x\in\ell^{q}$
\end_inset

.
\begin_inset Newline newline
\end_inset

מצד שני, לכל 
\begin_inset Formula $k$
\end_inset

 מתקיים
\begin_inset Formula 
\[
\Lambda_{k}^{q}x=\sum_{n=0}^{k-1}n^{-\beta}k^{-\alpha}\geq\sum_{n=0}^{k-1}k^{-\beta}k^{-\alpha}=k\cdot k^{-\alpha-\beta}=k^{1-\alpha-\beta}
\]

\end_inset

מתקיים 
\begin_inset Formula $1-\alpha-\beta>0$
\end_inset

 ולכן נקבל 
\begin_inset Formula $\Lambda_{k}^{q}x\rightarrow\infty$
\end_inset

, ובפרט 
\begin_inset Formula $\Lambda_{k}^{q}x$
\end_inset

 לא מתכנס ב-
\begin_inset Formula $\kaliComplex$
\end_inset

.
\begin_inset Newline newline
\end_inset

 לכן אם 
\begin_inset Formula $L$
\end_inset

 הוא אוסף כל האיברים 
\begin_inset Formula $x$
\end_inset

 ב-
\begin_inset Formula $\ell^{q}$
\end_inset

 עבורם קיים הגבול 
\begin_inset Formula $\lim_{k\rightarrow0}\Lambda_{k}^{q}x$
\end_inset

, אז ממה שראינו מתקיים 
\begin_inset Formula $\ell^{p}\subseteq L$
\end_inset

 אבל 
\begin_inset Formula $L\neq\ell^{q}$
\end_inset

.
\begin_inset Newline newline
\end_inset

לכן 
\begin_inset Formula $L$
\end_inset

 היא מקטגוריה ראשונה ב-
\begin_inset Formula $\ell^{q}$
\end_inset

, ולכן 
\begin_inset Formula $\ell^{p}$
\end_inset

 היא מקטגוריה ראשונה גם כן ב-
\begin_inset Formula $\ell^{q}$
\end_inset

 כנדרש.
\begin_inset Newline newline
\end_inset

אם 
\begin_inset Formula $p=1$
\end_inset

, ההוכחה דומה אבל צריך להגדיר 
\begin_inset Formula 
\[
y_{k}\left(n\right)=\begin{cases}
k^{-1} & n<2^{k}\\
0 & n\geq2^{k}
\end{cases}
\]

\end_inset

ואז 
\begin_inset Formula $\left\Vert y_{k}\right\Vert _{\infty}=k^{-1},\left\Vert y_{k}\right\Vert _{q^{*}}=2^{k}k^{-1}$
\end_inset

.
 כמו קודם נקבל פונקציונלים 
\begin_inset Formula $\Lambda_{k}^{p},\Lambda_{k}^{q}$
\end_inset

 בעלי אותם תכונות, ומאותו טיעון נקבל 
\begin_inset Formula $\Lambda_{k}^{p}x\rightarrow0$
\end_inset

 לכל 
\begin_inset Formula $x\in\ell^{p}$
\end_inset

.
\begin_inset Newline newline
\end_inset

הפעם אם נבחר 
\begin_inset Formula $x\left(n\right)=n^{-2}$
\end_inset

 אז ברור ש-
\begin_inset Formula $x\in\ell^{p}$
\end_inset

, ומצד שני 
\begin_inset Formula 
\[
\Lambda_{k}^{p}x=\sum_{n=0}^{2^{k}-1}n^{-2}k^{-1}\geq\sum_{n=0}^{2^{k}-1}k^{-3}=2^{k}k^{-3}\rightarrow\infty
\]

\end_inset

ומכאן הכול אותו הדבר.
\end_layout

\begin_layout Enumerate
יהיו 
\begin_inset Formula $1\leq p<q\leq\infty$
\end_inset

.
 אז 
\begin_inset Formula $\ell^{p}\subseteq\ell^{q}$
\end_inset

.
\begin_inset Newline newline
\end_inset

נניח 
\begin_inset Formula $q=\infty$
\end_inset

.
 אז לכל 
\begin_inset Formula $x\in\ell^{p}$
\end_inset

 מתקיים 
\begin_inset Formula 
\[
\left\Vert x\right\Vert _{\infty}^{p}=\left(\sup_{n\in\kaliNatural}\left|x\left(n\right)\right|\right)^{p}=\sup_{n\in\kaliNatural}\left|x\left(n\right)\right|^{p}\leq\sum_{n=0}^{\infty}\left|x\left(n\right)\right|^{p}=\left\Vert x\right\Vert _{p}^{p}
\]

\end_inset

ולכן 
\begin_inset Formula $\left\Vert x\right\Vert _{\infty}\leq\left\Vert x\right\Vert _{p}$
\end_inset

.
\begin_inset Newline newline
\end_inset

אחרת, 
\begin_inset Formula $q<\infty$
\end_inset

.
\begin_inset Newline newline
\end_inset

יהא 
\begin_inset Formula $x\in\ell^{p}$
\end_inset

.
 אם 
\begin_inset Formula $x\neq0$
\end_inset

 אז יש 
\begin_inset Formula $t>0$
\end_inset

 עבורו 
\begin_inset Formula $\left\Vert tx\right\Vert _{p}<1$
\end_inset

, ולכן לכל 
\begin_inset Formula $n$
\end_inset

 מתקיים 
\begin_inset Formula $t\left|x\left(n\right)\right|<1$
\end_inset

, ולכן לכל 
\begin_inset Formula $n$
\end_inset

 מתקיים 
\begin_inset Formula $t^{p}\left|x\left(n\right)\right|^{p}>t^{q}\left|x\left(n\right)\right|^{q}$
\end_inset

, ולכן
\begin_inset Formula 
\[
\left\Vert tx\right\Vert _{q}=\left(\sum_{n=0}^{\infty}t^{q}\left|x\left(n\right)\right|^{q}\right)^{\nicefrac{1}{q}}<\left(\sum_{n=0}^{\infty}t^{p}\left|x\left(n\right)\right|^{p}\right)^{\nicefrac{1}{p}}=\left\Vert tx\right\Vert _{p}
\]

\end_inset

ולכן 
\begin_inset Formula $t\left\Vert x\right\Vert _{q}\leq t\left\Vert x\right\Vert _{p}$
\end_inset

 ולכן 
\begin_inset Formula $\left\Vert x\right\Vert _{q}\leq\left\Vert x\right\Vert _{p}$
\end_inset

, לכל 
\begin_inset Formula $x\neq0$
\end_inset

.
 האי-שוויון הזה נכון בבירור גם עבור 
\begin_inset Formula $x=0$
\end_inset

, ולכן 
\begin_inset Formula $\left\Vert x\right\Vert _{q}\leq\left\Vert x\right\Vert _{p}$
\end_inset

 לכל 
\begin_inset Formula $x\in\ell^{q}$
\end_inset

.
\begin_inset Newline newline
\end_inset

אז בין אם 
\begin_inset Formula $q=\infty$
\end_inset

 או 
\begin_inset Formula $q<\infty$
\end_inset

 קיבלנו אז הא
\begin_inset Quotes erd
\end_inset

ש 
\begin_inset Formula $\left\Vert x\right\Vert _{q}\leq\left\Vert x\right\Vert _{p}$
\end_inset

, ועכשיו נמשיך.
\begin_inset Newline newline
\end_inset

תהא 
\begin_inset Formula $\iota:\ell^{p}\rightarrow\ell^{q}$
\end_inset

 העתקת הזהות.
 נוכיח שהיא רציפה.
 זו בבירור העתקה לינארית, ולכן מספיק להוכיח רציפות ב-
\begin_inset Formula $0$
\end_inset

.
\begin_inset Newline newline
\end_inset

יהא 
\begin_inset Formula $\varepsilon>0$
\end_inset

.
 אז לכל 
\begin_inset Formula $x\in\ell^{p}$
\end_inset

 עבורו 
\begin_inset Formula $\left\Vert x\right\Vert _{p}<\varepsilon$
\end_inset

, מתקיים בפרט 
\begin_inset Formula $\left\Vert x\right\Vert _{q}\leq\left\Vert x\right\Vert _{p}<\varepsilon$
\end_inset

 ולכן קיבלנו את הדרוש.
\begin_inset Newline newline
\end_inset


\begin_inset Formula $\ell^{p}$
\end_inset

 הוא מרחב בנך ובפרט מרחב-
\begin_inset Formula $F$
\end_inset

, ולכן אם 
\begin_inset Formula $\iota\left(\ell^{p}\right)$
\end_inset

 היא מקטגוריה שניה ב-
\begin_inset Formula $\ell^{q}$
\end_inset

, אז ממשפט ההעתקה הפתוחה 
\begin_inset Formula $\iota\left(\ell^{p}\right)=\ell^{q}$
\end_inset

.
\begin_inset Newline newline
\end_inset

אבל 
\begin_inset Formula $\iota\left(\ell^{p}\right)=\ell^{q}\neq\ell^{p}$
\end_inset

, ולכן 
\begin_inset Formula $\iota\left(\ell^{p}\right)=\ell^{p}$
\end_inset

 היא לא מקטגוריה שניה ב-
\begin_inset Formula $\ell^{q}$
\end_inset

, ולכן 
\begin_inset Formula $\ell^{p}$
\end_inset

 היא מקטגוריה ראשונה ב-
\begin_inset Formula $\ell^{q}$
\end_inset

 כנדרש.
