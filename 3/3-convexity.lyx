\[
\intop_{\left\{ f_{i}\geq N\right\} }\left|f_{i}\right|dm<\frac{r}{4\left\Vert g_{0}\right\Vert _{\infty}}
\]

\end_inset

נסמן 
\begin_inset Formula $\varepsilon=\left(4N\left\Vert g_{0}\right\Vert _{\infty}\right)^{-1}r$
\end_inset

