 & =\intop_{0}^{\nicefrac{1}{2}-\delta}\lambda dt+\left(\intop_{\nicefrac{1}{2}-\delta}^{\nicefrac{1}{2}}\delta^{-1}\lambda\left(\frac{1}{2}-t\right)dt-\intop_{\nicefrac{1}{2}}^{\nicefrac{1}{2}+\delta}\delta^{-1}\lambda\left(\frac{1}{2}-t\right)dt\right)-\intop_{\nicefrac{1}{2}+\delta}^{1}\left(-\lambda\right)dt\\
 & =\left(1-2\delta+\delta^{-1}\left(\intop_{\nicefrac{1}{2}-\delta}^{\nicefrac{1}{2}}\left(\frac{1}{2}-t\right)dt-\intop_{\nicefrac{1}{2}}^{\nicefrac{1}{2}+\delta}\left(\frac{1}{2}-t\right)dt\right)\right)\lambda
