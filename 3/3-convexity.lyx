\begin{align*}
\intop_{E}\left|f_{i}\right|dm & =\intop_{E\cap\left\{ f_{i}<N\right\} }\left|f_{i}\right|dm+\intop_{E\cap\left\{ f_{i}\geq N\right\} }\left|f_{i}\right|dm\\
 & \leq m\left(E\right)\cdot N+\frac{r}{4\left\Vert g_{0}\right\Vert _{\infty}}<\frac{r}{2\left\Vert g_{0}\right\Vert _{\infty}}
\end{align*}

\end_inset

