\left\Vert x\right\Vert ^{2} & =\left\langle \sum_{i=1}^{k}\frac{\lambda_{i}}{n_{i}}u_{i},\sum_{j=1}^{k}\frac{\lambda_{j}}{n_{j}}u_{j}\right\rangle =\sum_{i=1}^{k}\sum_{j=1}^{k}\frac{\lambda_{i}}{n_{i}}\frac{\lambda_{j}}{n_{j}}\left\langle u_{i},u_{j}\right\rangle \\
 & =\sum_{i=1}^{k}\left(\frac{\lambda_{i}}{n_{i}}\right)^{2}=\sum_{n=1}^{\infty}\left(\left(\sum_{1\leq i\leq k,n_{i}=n}\lambda_{i}^{2}\right)\frac{1}{n^{2}}\right)\\
 & \leq\sum_{n=1}^{\infty}\left(\left(\sum_{i=1}^{k}\lambda_{i}\right)\frac{1}{n^{2}}\right)=\sum_{n=1}^{\infty}\frac{1}{n^{2}}
\end{align*}

\end_inset

