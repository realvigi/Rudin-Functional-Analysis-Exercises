\end_inset

.
\begin_inset Newline newline
\end_inset

נבחר 
\begin_inset Formula $\delta>0$
\end_inset

 קטן מספיק עבורו 
\begin_inset Formula $2\sqrt{2\delta M}<\nicefrac{\varepsilon}{2}$
\end_inset

.
\begin_inset Newline newline
\end_inset

לכל 
\begin_inset Formula $x\in I$
\end_inset

 נגדיר 
\begin_inset Formula 
\[
h\left(x\right)=\begin{cases}
g\left(x\right) & \left|x\right|>\delta\\
-\delta^{-1}xg\left(-\delta\right)+\alpha\left(1+\delta^{-1}x\right) & -\delta\leq x\leq0\\
\delta^{-1}xg\left(\delta\right)+\left(1-\delta^{-1}x\right)\alpha & 0\leq x\leq\delta
\end{cases}
\]

\end_inset

אז 
\begin_inset Formula $h$
\end_inset

 רציפה ו-
\begin_inset Formula $h\left(0\right)=\alpha$
\end_inset

 ולכן 
\begin_inset Formula $h\in E_{\alpha}$
\end_inset

.
\begin_inset Newline newline
\end_inset

כמו כן לכל 
\begin_inset Formula $x\in I$
\end_inset

, 
\begin_inset Formula $h\left(x\right)$
\end_inset

 היא צירוף עבור של איברים בקבוצה 
\begin_inset Formula $\left\{ z:\left|z\right|\leq M\right\} $
\end_inset

 ומכך שזו קבוצה קמורה הרי ש-
\begin_inset Formula $\left|h\right|\leq M$
\end_inset

 בכל 
\begin_inset Formula $I$
\end_inset

.
\begin_inset Newline newline
\end_inset

לכן נקבל
\begin_inset Formula 
\begin{align*}
\left\Vert g-h\right\Vert _{2}^{2} & =\intop_{I}\left|g-h\right|^{2}dm=\intop_{\left[-\delta,\delta\right]}\left|g-h\right|^{2}dm\\
 & \leq\intop_{\left[-\delta,\delta\right]}\left(\left|g\right|+\left|h\right|\right)^{2}dm=\intop_{\left[-\delta,\delta\right]}\left(2M\right)^{2}dm\\
 & =8\delta M^{2}
\end{align*}

\end_inset

כלומר 
\begin_inset Formula $\left\Vert g-h\right\Vert _{2}=2\sqrt{2\delta M}<\nicefrac{\varepsilon}{2}$
\end_inset

 ולכן
\begin_inset Formula 
\[
\left\Vert f-h\right\Vert _{2}\leq\left\Vert f-g\right\Vert _{2}+\left\Vert g-h\right\Vert _{2}<\frac{\varepsilon}{2}+\frac{\varepsilon}{2}=\varepsilon
\]

\end_inset

